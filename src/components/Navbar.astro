---
export interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

// Helpers para saber si estamos dentro de una sección (incluye subpáginas)
const isCapacidadesActive = currentPath.startsWith("/capacidades");
const isIndustriasActive = currentPath.startsWith("/industrias");
const isNosotrosActive = currentPath.startsWith("/nosotros");

// Clases comunes extraídas para mantener el HTML limpio
// 1. BASE: Todos los enlaces son rojos por defecto (text-primary) y relativos (para la línea inferior)
const baseLinkClass =
  "relative flex items-center gap-1 h-full px-2 transition-all duration-300 cursor-pointer text-primary";

// 2. ACTIVO (Página actual):
// - Usa 'font-bold' real porque carga así desde el principio y no hace saltar nada.
// - La línea inferior se dibuja con 'after:' pegada abajo, sin empujar el texto hacia arriba.
const activeClass =
  "font-bold after:absolute after:bottom-[16px] after:left-0 after:w-full after:h-[5px] after:bg-primary";

// 3. INACTIVO DESPLEGABLE (Capacidades, Industrias, Nosotros):
// - font-medium (normal).
// - group-hover:[text-shadow...] -> Engrosa la letra visualmente en hover SIN mover a los lados.
// - La línea inferior (bg-primary/40) aparece suavemente.
// 3. INACTIVO DESPLEGABLE:
const dropdownInactiveClass =
  "font-medium group-hover:[text-shadow:0.4px_0_0_currentColor,-0.4px_0_0_currentColor] after:absolute after:bottom-[16px] after:left-0 after:w-full after:h-[5px] after:bg-primary/40 after:opacity-0 group-hover:after:opacity-100 after:transition-opacity after:duration-300";

// 4. INACTIVO SIMPLE:
const simpleInactiveClass =
  "font-medium hover:[text-shadow:0.4px_0_0_currentColor,-0.4px_0_0_currentColor] after:absolute after:bottom-[16px] after:left-0 after:w-full after:h-[5px] after:bg-primary/40 after:opacity-0 hover:after:opacity-100 after:transition-opacity after:duration-300";
---

