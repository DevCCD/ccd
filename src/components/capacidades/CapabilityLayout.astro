---
import Layout from "../../layouts/Layout.astro";
import EtiquetaArea from "./EtiquetaArea.astro";
import ValorCliente from "./ValorCliente.astro";
import NuestroTrabajoCapacidad from "./NuestroTrabajoCapacidad.astro";
import { teamMembers } from "../../data/teamData";

interface Props {
    title: string;
    area: string;
    areaColor: string;
    headerImage: string;
    valorClienteIntro?: string;
    valorClienteBullets?: { text: string; image: string }[];
    nuestroTrabajo?: { bullet: string; image: string; subBullets?: string[] }[];
    specialistSlugs?: string[];
}

const {
    title,
    area,
    areaColor,
    headerImage,
    valorClienteIntro,
    valorClienteBullets,
    nuestroTrabajo,
    specialistSlugs = [],
} = Astro.props;

const specialists = specialistSlugs
    .map((slug) => teamMembers[slug as keyof typeof teamMembers])
    .filter(Boolean);
---

<Layout title={`${title} - Capacidades | CCD`}>
    <!-- HERO BANNERS -->
    <section
        class="relative w-full h-[65vh] md:h-[75vh] overflow-hidden bg-gray-900"
        style={`border-bottom-color: ${areaColor};`}
    >
        <img
            src={headerImage ||
                "https://res.cloudinary.com/ccdcloudy/image/upload/v1773305978/Web%20CCD/paises/comercio-exterior_indice-de-conectividad-global-050424-010226_gvj4pp.jpg"}
            alt={title}
            class="w-full h-full object-cover opacity-80 transition-transform duration-[30000ms] hover:scale-110"
        />
        <div
            class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/10"
        >
            <div
                class="container mx-auto px-6 lg:px-12 h-full flex flex-col justify-end pb-12 md:pb-24"
            >
                {
                    /*
                <div class="mb-8 animate-fade-in-up">
                    <EtiquetaArea area={area} color={areaColor} />
                </div>
                */
                }
                <div
                    class="space-y-6 max-w-5xl animate-fade-in-up"
                    style="animation-delay: 0.1s;"
                >
                    <h1
                        class="font-serif text-5xl md:text-7xl lg:text-8xl font-black text-white leading-tight drop-shadow-2xl"
                    >
                        {title}
                    </h1>
                </div>
            </div>
        </div>
    </section>

    <!-- GENERACIÓN DE VALOR AL CLIENTE -->
    {
        ((valorClienteBullets && valorClienteBullets.length > 0) ||
            valorClienteIntro) && (
            <ValorCliente
                intro={valorClienteIntro || ""}
                bullets={valorClienteBullets || []}
            />
        )
    }

    <!-- NUESTRO TRABAJO (genérico desde data) -->
    {
        nuestroTrabajo && nuestroTrabajo.length > 0 && (
            <NuestroTrabajoCapacidad workList={nuestroTrabajo} />
        )
    }

    <!-- SLOT: Contenido personalizado por página (ej. Nuestro Trabajo custom) -->
    <slot />

    <!-- ESPECIALISTAS SEC -->
    {
        specialists && specialists.length > 0 && (
            <section class="bg-gradient-to-b from-secondary-light/20 to-secondary py-20 border-t border-gray-100">
                <div class="container mx-auto px-6 lg:px-12 max-w-[1600px] flex flex-col items-center text-center w-full">
                    <h4 class="font-serif text-2xl md:text-4xl font-bold text-gray-900 mb-16">
                        Nuestro Equipo
                    </h4>
                    <div class=" flex flex-col md:flex-row justify-center items-center md:items-stretch gap-6 md:gap-0 md:divide-x divide-gray-100 w-full max-w-[1400px]">
                        {specialists.map((member) => (
                            <a
                                href={`/nosotros/equipo/${member.slug}`}
                                class={`group flex flex-col items-center text-center w-full px-8 py-12 bg-white transition-all duration-300 hover:shadow-xl relative z-10 ${specialists.length === 1 ? "max-w-[450px]" : "md:flex-1"}`}
                            >
                                <div class="w-48 h-48 md:w-56 md:h-56 lg:w-[280px] lg:h-[280px] mb-10 overflow-hidden rounded-full bg-gray-100 border-4 border-gray-50/50">
                                    <img
                                        src={member.photos?.casual}
                                        alt={member.name}
                                        class="w-full h-full object-cover object-top scale-225 transition-transform duration-700 group-hover:scale-[1.1]"
                                    />
                                </div>
                                <h4 class="font-serif font-bold text-2xl md:text-[1.85rem] text-gray-900 group-hover:text-primary transition-colors leading-tight">
                                    {member.name}
                                </h4>
                                <p class="text-gray-900 text-[14px] md:text-[16px] mt-4 tracking-wide">
                                    {member.role}
                                </p>
                            </a>
                        ))}
                    </div>
                    <div class="mt-16 w-full flex justify-center">
                        <a
                            href="/nosotros/equipo"
                            class="inline-flex items-center justify-center px-10 py-4 bg-primary text-white font-sans font-bold text-[18px] hover:bg-primary-dark transition-colors duration-300 hover:shadow-xl group"
                        >
                            Ver Equipo CCD
                            <svg
                                class="w-6 h-6 ml-3 transform group-hover:translate-x-1 transition-transform"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M9 5l7 7-7 7"
                                />
                            </svg>
                        </a>
                    </div>
                </div>
            </section>
        )
    }

</Layout>

<style>
    .animate-fade-in-up {
        animation: fadeInUp 1s ease-out forwards;
        opacity: 0;
        transform: translateY(20px);
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
