---
import Layout from "../../layouts/Layout.astro";
import EtiquetaArea from "./EtiquetaArea.astro";
import ValorCliente from "./ValorCliente.astro";
import NuestroTrabajoCapacidad from "./NuestroTrabajoCapacidad.astro";

interface Props {
    title: string;
    area: string;
    areaColor: string;
    headerImage: string;
    valorClienteIntro?: string;
    valorClienteBullets?: { text: string; image: string }[];
    nuestroTrabajo?: { bullet: string; image: string; subBullets?: string[] }[];
}

const {
    title,
    area,
    areaColor,
    headerImage,
    valorClienteIntro,
    valorClienteBullets,
    nuestroTrabajo,
} = Astro.props;
---

<Layout title={`${title} - Capacidades | CCD`}>
    <!-- HERO BANNERS -->
    <section
        class="relative w-full h-[65vh] md:h-[75vh] overflow-hidden bg-gray-900"
        style={`border-bottom-color: ${areaColor};`}
    >
        <img
            src={headerImage ||
                "https://res.cloudinary.com/ccdcloudy/image/upload/v1773305978/Web%20CCD/paises/comercio-exterior_indice-de-conectividad-global-050424-010226_gvj4pp.jpg"}
            alt={title}
            class="w-full h-full object-cover opacity-80 transition-transform duration-[30000ms] hover:scale-110"
        />
        <div
            class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/10"
        >
            <div
                class="container mx-auto px-6 lg:px-12 h-full flex flex-col justify-end pb-12 md:pb-24"
            >
                {/*
                <div class="mb-8 animate-fade-in-up">
                    <EtiquetaArea area={area} color={areaColor} />
                </div>
                */}
                <div
                    class="space-y-6 max-w-5xl animate-fade-in-up"
                    style="animation-delay: 0.1s;"
                >
                    <h1
                        class="font-serif text-5xl md:text-7xl lg:text-8xl font-black text-white leading-tight drop-shadow-2xl"
                    >
                        {title}
                    </h1>
                </div>
            </div>
        </div>
    </section>

    <!-- GENERACIÓN DE VALOR AL CLIENTE -->
    {
        ((valorClienteBullets && valorClienteBullets.length > 0) ||
            valorClienteIntro) && (
            <ValorCliente
                intro={valorClienteIntro || ""}
                bullets={valorClienteBullets || []}
            />
        )
    }

    <!-- NUESTRO TRABAJO -->
    {
        nuestroTrabajo && nuestroTrabajo.length > 0 && (
            <NuestroTrabajoCapacidad workList={nuestroTrabajo} />
        )
    }

    <!-- ESPACIO PARA CUSTOM HTML FUTURO DE CADA PÁGINA ESPECÍFICA -->
    <slot />
</Layout>

<style>
    .animate-fade-in-up {
        animation: fadeInUp 1s ease-out forwards;
        opacity: 0;
        transform: translateY(20px);
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
