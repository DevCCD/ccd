---
import Layout from "../../layouts/Layout.astro";

interface Props {
    title: string;
    description: string;
    headerImage: string;
    headerImagePosition?: string;
    valueGenerationItems: { text: string; image: string; imageAlt?: string }[];
    ourWorkItems: { text: string; image: string; imageAlt?: string; bullets?: string[] }[];
    specialists: any[];
    industries: any[];
    nextCapability?: { title: string; link: string };
}

const {
    title,
    description,
    headerImage,
    headerImagePosition = "center",
    valueGenerationItems,
    ourWorkItems,
    specialists,
    industries,
    nextCapability,
} = Astro.props;
---

<Layout title={`${title} - CCD`}>
    <!-- BANNER DE ALTO IMPACTO -->
    <section class="relative w-full h-[65vh] md:h-[75vh] overflow-hidden bg-gray-900">
        <img
            src={headerImage}
            alt={title}
            class="w-full h-full object-cover transition-transform duration-[30000ms]"
            style={{ objectPosition: headerImagePosition }}
        />
        <!-- Overlay sofisticado con degradado para legibilidad -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent">
            <div class="container mx-auto px-6 lg:px-12 h-full flex flex-col justify-end pb-8 md:pb-10">
                <div class="space-y-4 max-w-4xl animate-fade-in-up">
                    <h1 class="font-serif text-5xl md:text-7xl font-black text-white leading-tight drop-shadow-2xl">
                        {title}
                    </h1>
                    <div class="w-24 h-2 bg-primary rounded-full shadow-lg"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- GENERACIÓN DE VALOR CLIENTE -->
    {valueGenerationItems && valueGenerationItems.length > 0 && (
        <section class="bg-gray-100 pb-24">
            <!-- Título Principal con Degradado -->
            <div class="relative bg-gradient-to-br from-[#6B1A29] via-[#910121] to-[#4A0D15] py-24 md:py-32 text-white overflow-hidden shadow-2xl mb-16 md:mb-24">
                <!-- Capa extra para profundidad -->
                <div class="absolute inset-0 bg-black/30 pointer-events-none"></div>
                <div class="absolute -top-32 -left-32 w-96 h-96 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
                <div class="absolute -bottom-32 -right-32 w-96 h-96 bg-black/20 rounded-full blur-3xl pointer-events-none"></div>
                
                <div class="container mx-auto px-6 lg:px-12 max-w-[1600px] text-center relative z-10">
                    <h2 class="font-serif text-5xl md:text-6xl lg:text-7xl font-bold mb-8 drop-shadow-xl tracking-wide">
                        Generación de <span class="font-light italic text-[#ffb3c1]">Valor Cliente</span>
                    </h2>
                    <div class="w-32 h-1 bg-white/50 mx-auto mb-10 rounded-full"></div>
                    <p class="font-sans text-2xl lg:text-[1.75rem] font-light leading-[1.8] max-w-5xl mx-auto text-white/95 drop-shadow-md">
                        {description}
                    </p>
                </div>
            </div>

            <div class="container mx-auto px-6 lg:px-12 max-w-[1600px] flex flex-col gap-12 md:gap-16">
                <slot name="before-value" />

                <!-- Layout Premium de Alto Impacto para cada Value Item -->
                {valueGenerationItems.map((item, index) => {
                    const isEven = index % 2 === 0;
                    
                    return (
                        <div class="group relative w-full min-h-[500px] lg:min-h-[70vh] rounded-[2rem] overflow-hidden shadow-[0_10px_30px_rgba(0,0,0,0.15)] flex items-center bg-gray-900 transform transition-all duration-700 hover:-translate-y-2 hover:shadow-[0_25px_60px_rgba(0,0,0,0.4)]">
                            <!-- Huge Image Background -->
                            <img
                                src={item.image}
                                alt={item.imageAlt || item.text}
                                class="absolute inset-0 w-full h-full object-cover transition-transform duration-[15000ms] ease-out group-hover:scale-110 opacity-80"
                            />
                            
                            <!-- Heavy Gradient Overlay based on orientation -->
                            <div class={`absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r ${isEven ? 'from-black/95 via-black/80 md:via-black/50 to-transparent' : 'md:from-transparent md:via-black/50 from-black/95 to-black/95'}`}></div>
                            
                            <!-- Text Content -->
                            <div class={`relative z-10 w-full px-8 py-16 md:px-16 lg:px-24 flex ${isEven ? 'justify-start' : 'justify-start md:justify-end'}`}>
                                <div class="max-w-4xl">
                                    <div class={`w-24 h-2 bg-primary mb-10 rounded-full shadow-[0_0_20px_rgba(145,1,33,0.8)] ${!isEven && 'md:ml-auto md:mr-0'}`}></div>
                                    <p class={`font-sans text-3xl md:text-4xl text-white font-light leading-[1.6] md:leading-[1.7] drop-shadow-xl tracking-wide ${!isEven && 'md:text-right'}`}>
                                        {item.text}
                                    </p>
                                </div>
                            </div>
                        </div>
                    );
                })}
            </div>
        </section>
    )}

    <!-- NUESTRO TRABAJO -->
    {ourWorkItems && ourWorkItems.length > 0 && (
        <section class="bg-gray-100 py-24 border-t border-gray-200 relative overflow-hidden" id="nuestro-trabajo">
            <!-- Decorative background gradient -->
            <div class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-b from-gray-200/80 to-transparent pointer-events-none"></div>
            
            <div class="container mx-auto px-6 lg:px-12 max-w-[1600px] relative z-10">
                <div class="text-center md:text-left mb-16">
                    <h2 class="font-serif text-5xl md:text-6xl font-bold text-gray-900 mb-6 drop-shadow-sm tracking-tight">
                        Nuestro Trabajo
                    </h2>
                    <div class="w-32 h-1.5 bg-gradient-to-r from-[#910121] to-[#ffb3c1] rounded-full"></div>
                </div>

                <div class="mb-12">
                    <slot name="before-work" />
                </div>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-8 lg:gap-12">
                    {ourWorkItems.map((work, index) => {
                        const total = ourWorkItems.length;
                        let colClass = "md:col-span-6 lg:col-span-4"; // 3 columnas por defecto

                        if (total === 1) {
                            colClass = "md:col-span-12 lg:col-span-8 lg:col-start-3";
                        } else if (total === 2) {
                            colClass = "md:col-span-6";
                        } else if (total === 4) {
                            colClass = "md:col-span-6 lg:col-span-3"; // 4 columnas
                        } else if (total === 5) {
                            colClass = index < 2 ? "md:col-span-6" : "md:col-span-6 lg:col-span-4";
                        } else if (total === 7) {
                            colClass = index < 4 ? "md:col-span-6 lg:col-span-3" : "md:col-span-6 lg:col-span-4";
                        } else if (total === 8) {
                            colClass = "md:col-span-6 lg:col-span-3"; // 4 columnas
                        } else if (total === 10) {
                            colClass = index < 4 ? "md:col-span-6 lg:col-span-3" : "md:col-span-6 lg:col-span-4";
                        } else if (total === 11) {
                            colClass = index < 8 ? "md:col-span-6 lg:col-span-3" : "md:col-span-6 lg:col-span-4";
                        }

                        return (
                            <div class={`group block mb-6 bg-white rounded-2xl shadow-lg hover:shadow-[0_20px_40px_rgba(0,0,0,0.12)] overflow-hidden flex flex-col transform transition-all duration-500 hover:-translate-y-2 ${colClass}`}>
                                <div class="relative overflow-hidden aspect-[16/10] flex-shrink-0">
                                    <img
                                        src={work.image}
                                        alt={work.imageAlt || work.text}
                                        class="w-full h-full object-cover transition-transform duration-[10000ms] group-hover:scale-110"
                                    />
                                    <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-transparent to-transparent opacity-60 group-hover:opacity-100 transition-opacity duration-500"></div>
                                </div>
                                <div class="p-8 lg:p-10 flex-grow flex flex-col bg-gradient-to-b from-white to-gray-50/50 relative">
                                    <!-- decorative top line -->
                                    <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-transparent via-primary/20 to-transparent group-hover:via-primary transition-all duration-700"></div>
                                    
                                    <h4 class="font-serif text-xl md:text-[1.35rem] font-bold text-gray-900 mb-6 transition-colors duration-300 group-hover:text-primary leading-[1.5]">
                                        {work.text}
                                    </h4>
                                    
                                    {work.bullets && work.bullets.length > 0 && (
                                        <div class="mt-auto pt-6 border-t border-gray-100">
                                            <ul class={`${work.bullets.length > 5 ? 'grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4' : 'space-y-4'}`}>
                                                {work.bullets.map((bullet) => (
                                                    <li class="flex items-start group/bullet">
                                                        <span class="w-1.5 h-1.5 rounded-full bg-primary/40 mt-2 flex-shrink-0 group-hover/bullet:bg-primary group-hover/bullet:shadow-[0_0_8px_rgba(145,1,33,0.6)] transition-all duration-300" />
                                                        <span class="text-gray-600 text-[0.95rem] ml-3 leading-relaxed group-hover/bullet:text-gray-900 transition-colors duration-300">{bullet}</span>
                                                    </li>
                                                ))}
                                            </ul>
                                        </div>
                                    )}
                                </div>
                            </div>
                        );
                    })}
                </div>

                <!-- Siguiente Capacidad -->
                {nextCapability && (
                    <div class="pt-16 max-w-4xl mx-auto">
                        <a
                            href={nextCapability.link}
                            class="group flex items-center justify-between p-8 rounded-2xl bg-white shadow-md hover:shadow-xl border border-gray-100 hover:border-primary/30 transition-all duration-300 transform hover:-translate-y-1"
                        >
                            <div>
                                <span class="text-sm font-bold text-primary uppercase tracking-widest">Siguiente Capacidad</span>
                                <h4 class="text-2xl font-serif font-bold text-gray-900 mt-2">
                                    {nextCapability.title}
                                </h4>
                            </div>
                            <div class="w-12 h-12 rounded-full bg-gray-50 border border-gray-200 flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                </svg>
                            </div>
                        </a>
                    </div>
                )}
            </div>
        </section>
    )}

    <!-- ESPECIALISTAS E INDUSTRIAS -->
    {(((specialists && specialists.length > 0) || (industries && industries.length > 0))) && (
        <section class="bg-gradient-to-b from-secondary-light/20 to-secondary py-20 border-t border-gray-100">
            <div class="container mx-auto px-6 lg:px-12 max-w-[1600px] space-y-24">
                
                {/* Especialistas */}
                {specialists && specialists.length > 0 && (
                    <div class="flex flex-col items-center text-center w-full">
                        <h2 class="font-serif text-3xl md:text-5xl font-bold text-gray-900 mb-16">
                            Especialistas
                        </h2>
                        <div class="flex flex-col md:flex-row justify-center items-center md:items-stretch gap-6 md:gap-0 md:divide-x divide-gray-100 w-full max-w-[1400px] flex-wrap">
                            {specialists.map((member) => (
                                <a
                                    href={`/nosotros/equipo/${member.slug}`}
                                    class="group flex flex-col items-center text-center w-full md:flex-1 px-4 lg:px-8 py-10 bg-white transition-all duration-300 hover:shadow-xl relative z-10"
                                >
                                    <div class="w-48 h-48 md:w-48 md:h-48 lg:w-56 lg:h-56 mb-8 overflow-hidden rounded-full bg-gray-100 border-4 border-gray-50/50">
                                        <img
                                            src={member.image}
                                            alt={member.name}
                                            class="w-full h-full object-cover object-top scale-225 transition-transform duration-700 group-hover:scale-[1.1]"
                                        />
                                    </div>
                                    <h4 class="font-serif font-bold text-xl md:text-2xl text-gray-900 group-hover:text-primary transition-colors leading-tight">
                                        {member.name}
                                    </h4>
                                    <p class="text-gray-900 text-sm md:text-base mt-3 tracking-wide px-2">
                                        {member.role}
                                    </p>
                                </a>
                            ))}
                        </div>
                    </div>
                )}

                {/* Industrias Relacionadas */}
                {industries && industries.length > 0 && (
                    <div>
                        <h2 class="font-serif text-3xl md:text-5xl font-bold text-gray-900 mb-12 border-b-2 border-primary pb-4 inline-block text-center w-full md:w-auto md:text-left">
                            Industrias Relacionadas
                        </h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                            {industries.map((industry) => (
                                <a href={industry.link} class="group block bg-white shadow-sm overflow-hidden hover:shadow-md transition-shadow">
                                    <div class="aspect-video bg-gray-100 overflow-hidden">
                                        <img
                                            src={industry.image}
                                            alt={industry.title}
                                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                        />
                                    </div>
                                    <div class="p-5 flex items-center justify-between">
                                        <h3 class="font-serif text-lg font-bold text-gray-900 group-hover:text-primary transition-colors">
                                            {industry.title}
                                        </h3>
                                        <svg
                                            class="w-5 h-5 text-primary opacity-0 group-hover:opacity-100 transform -translate-x-2 group-hover:translate-x-0 transition-all duration-300 flex-shrink-0"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="3"
                                            viewBox="0 0 24 24"
                                        >
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                        </svg>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                )}
            </div>
        </section>
    )}
</Layout>

<style>
    .animate-fade-in-up {
        animation: fadeInUp 0.8s ease-out forwards;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
