---
import Layout from "../../layouts/Layout.astro";

interface Props {
    title: string;
    headerImage: string;
    headerImagePosition?: string;
    paragraphs: string[];
    mainImage?: string;
    mainImageAlt?: string;
    flourishId: string;
    specialists: any[];
    capabilities: any[];
    introImage?: string;
    relatedWork?: { title: string; image: string; link?: string }[];
}

const {
    title,
    headerImage,
    headerImagePosition = "center",
    paragraphs,
    mainImage,
    mainImageAlt,
    flourishId,
    specialists,
    capabilities,
    introImage,
    relatedWork,
} = Astro.props;
---

<Layout title={`${title} - CCD`}>
    <!-- BANNER DE ALTO IMPACTO -->
    <section
        class="relative w-full h-[65vh] md:h-[75vh] overflow-hidden bg-gray-900"
    >
        <img
            src={headerImage}
            alt={title}
            class="w-full h-full object-cover transition-transform duration-[30000ms]"
            style={{ objectPosition: headerImagePosition }}
        />
        <!-- Overlay sofisticado con degradado para legibilidad -->
        <div
            class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"
        >
            <div
                class="container mx-auto px-6 lg:px-12 h-full flex flex-col justify-end pb-8 md:pb-10"
            >
                <div class="space-y-4 max-w-4xl animate-fade-in-up">
                    <h1
                        class="font-serif text-5xl md:text-7xl font-black text-white leading-tight drop-shadow-2xl"
                    >
                        {title}
                    </h1>
                    <div class="w-24 h-2 bg-primary rounded-full shadow-lg">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-white pt-16 md:pt-20 pb-16">
        <div class="container mx-auto px-6 lg:px-12 max-w-5xl">
            {
                paragraphs.length > 0 && (
                    <p class="font-sans text-md md:text-lg lg:text-xl text-gray-700 leading-[1.8] md:leading-[2.2] lg:leading-[1.6]">
                        {paragraphs[0]}
                    </p>
                )
            }
        </div>
    </section>

    {
        /* SECCIÓN 2: SEGUNDO PÁRRAFO + IMAGEN (Edge-to-Edge Full Width sin degradados) */
    }
    {
        (paragraphs.length > 1 || introImage) && (
            <section class="w-full flex flex-col lg:flex-row items-stretch">
                {introImage && (
                    <div
                        class={`relative w-full ${paragraphs.length > 1 ? "lg:w-1/2" : "w-full"} min-h-[400px] lg:min-h-[600px] overflow-hidden`}
                    >
                        <img
                            src={introImage}
                            alt="Visión estratégica"
                            class="absolute inset-0 w-full h-full object-cover"
                        />
                    </div>
                )}

                {paragraphs.length > 1 && (
                    <div
                        class={`w-full ${introImage ? "lg:w-1/2" : "w-full"} bg-secondary-light/50 py-8 px-12 flex flex-col justify-center`}
                    >
                        <div class="w-20 h-1.5 bg-secondary mb-10" />
                        <p class="font-sans text-md md:text-lg lg:text-xl text-gray-700 leading-[1.8] md:leading-[2.2] lg:leading-[1.6] px-0 py-0">
                            {paragraphs[1]}
                        </p>
                    </div>
                )}
            </section>
        )
    }

    {/* SECCIÓN 3: TERCER PÁRRAFO (Fondo primario, texto blanco) */}
    {
        paragraphs.length > 2 && (
            <section class="bg-gradient-to-b from-primary-dark via-primary to-primary/60 py-16 md:py-24">
                <div class="container mx-auto px-6 lg:px-12 max-w-5xl">
                    <p class="font-sans text-md md:text-lg lg:text-xl text-white leading-[1.8] md:leading-[2.2] lg:leading-[1.6]">
                        {paragraphs[2]}
                    </p>
                </div>
            </section>
        )
    }

    {
        /* SECCIÓN 4: CUARTO PÁRRAFO O MÁS (Vuelve al estilo del primer párrafo) */
    }
    {
        paragraphs.length > 3 && (
            <section class="bg-white pt-10 pb-16 md:pt-16 md:pb-24">
                <div class="container mx-auto px-6 lg:px-12 max-w-5xl space-y-10">
                    {paragraphs.slice(3).map((p) => (
                        <p class="font-sans text-md md:text-lg lg:text-xl text-gray-700 leading-[1.8] md:leading-[2.2] lg:leading-[1.6]">
                            {p}
                        </p>
                    ))}
                </div>
            </section>
        )
    }

    <!-- SECCIÓN NUESTROS PRODUCTOS Y SERVICIOS -->
    {
        relatedWork && relatedWork.length > 0 && (
            <section class="bg-gray-300 py-20 border-t border-gray-100">
                <div class="container mx-auto px-6 lg:px-12 max-w-[1600px]">
                    <h2 class="font-serif text-3xl md:text-5xl font-bold text-gray-900 mb-12 border-b-2 border-primary pb-4 inline-block">
                        Nuestros Productos y Servicios
                    </h2>

                    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 lg:gap-12">
                        {relatedWork.map((work, index) => {
                            const total = relatedWork.length;

                            // Lógica para grilla de 3 o 4 columnas cubriendo todos los espacios:
                            let colClass = "md:col-span-6 lg:col-span-4"; // 3 columnas por defecto

                            if (total === 1) {
                                colClass =
                                    "md:col-span-12 lg:col-span-8 lg:col-start-3";
                            } else if (total === 2) {
                                colClass = "md:col-span-6";
                            } else if (total === 4) {
                                colClass = "md:col-span-6 lg:col-span-3"; // 4 columnas
                            } else if (total === 5) {
                                colClass =
                                    index < 2
                                        ? "md:col-span-6"
                                        : "md:col-span-6 lg:col-span-4"; // 2 arriba, 3 abajo
                            } else if (total === 7) {
                                colClass =
                                    index < 4
                                        ? "md:col-span-6 lg:col-span-3"
                                        : "md:col-span-6 lg:col-span-4"; // 4 arriba, 3 abajo
                            } else if (total === 8) {
                                colClass = "md:col-span-6 lg:col-span-3"; // 4 columnas
                            } else if (total === 10) {
                                colClass =
                                    index < 4
                                        ? "md:col-span-6 lg:col-span-3"
                                        : "md:col-span-6 lg:col-span-4"; // 4 arriba, 6 abajo en filas de 3
                            } else if (total === 11) {
                                colClass =
                                    index < 8
                                        ? "md:col-span-6 lg:col-span-3"
                                        : "md:col-span-6 lg:col-span-4"; // 8 arriba en filas de 4, 3 abajo
                            }

                            return (
                                <a
                                    href={work.link || "#"}
                                    class={`group block mb-4 ${colClass}`}
                                >
                                    <div class="overflow-hidden mb-5 bg-gray-200 aspect-video">
                                        <img
                                            src={work.image}
                                            alt={work.title}
                                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                        />
                                    </div>
                                    <h4 class="font-serif text-xl font-bold text-gray-900 flex items-start justify-between group-hover:text-primary transition-colors duration-300">
                                        <span class="pr-4">{work.title}</span>
                                        <svg
                                            class="w-6 h-6 text-primary transform group-hover:translate-x-1 transition-transform mt-1 flex-shrink-0"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="3"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                d="M9 5l7 7-7 7"
                                            />
                                        </svg>
                                    </h4>
                                </a>
                            );
                        })}
                    </div>
                </div>
            </section>
        )
    }

    <!-- SECCIÓN FLOURISH (DATA) -->
    {
        flourishId && (
            <section class="bg-white py-20 border-t border-gray-100">
                <div class="container mx-auto px-6 lg:px-12 max-w-6xl">
                    <div class="min-h-[600px] flex items-center justify-center overflow-hidden">
                        <div
                            class="flourish-embed flourish-map w-full"
                            data-src={`visualisation/${flourishId}`}
                        >
                            <script src="https://public.flourish.studio/resources/embed.js" />
                        </div>
                    </div>
                </div>
            </section>
        )
    }

    <!-- CAPACIDADES Y ESPECIALISTAS (COMO FILAS BOTTOM) -->
    {
        ((capabilities && capabilities.length > 0) ||
            (specialists && specialists.length > 0)) && (
            <section class="bg-gradient-to-b from-secondary-light/20 to-secondary py-20 border-t border-gray-100">
                <div class="container mx-auto px-6 lg:px-12 max-w-[1600px] space-y-24">
                    {specialists && specialists.length > 0 && (
                        <div class="flex flex-col items-center text-center w-full">
                            <h2 class="font-serif text-3xl md:text-5xl font-bold text-gray-900 mb-16">
                                Especialistas
                            </h2>
                            {/* Usamos md:divide-x para replicar las líneas verticales de la referencia */}
                            <div class=" flex flex-col md:flex-row justify-center items-center md:items-stretch gap-6 md:gap-0 md:divide-x divide-gray-100 w-full max-w-[1400px]">
                                {specialists.map((member) => (
                                    <a
                                        href={`/nosotros/equipo/${member.slug}`}
                                        class="group flex flex-col items-center text-center w-full md:flex-1 px-8 py-12 bg-white transition-all duration-300 hover:shadow-xl relative z-10"
                                    >
                                        <div class="w-48 h-48 md:w-56 md:h-56 lg:w-[280px] lg:h-[280px] mb-10 overflow-hidden rounded-full bg-gray-100 border-4 border-gray-50/50">
                                            <img
                                                src={member.image}
                                                alt={member.name}
                                                class="w-full h-full object-cover object-top scale-225 transition-transform duration-700 group-hover:scale-[1.1]"
                                            />
                                        </div>
                                        <h4 class="font-serif font-bold text-2xl md:text-[1.85rem] text-gray-900 group-hover:text-primary transition-colors leading-tight">
                                            {member.name}
                                        </h4>
                                        <p class="text-gray-900 text-[14px] md:text-[16px] mt-4 tracking-wide">
                                            {member.role}
                                        </p>
                                    </a>
                                ))}
                            </div>
                        </div>
                    )}
                    {/* 
                    {capabilities && capabilities.length > 0 && (
                        <div>
                            <h2 class="font-serif text-3xl md:text-5xl font-bold text-gray-900 mb-12 border-b-2 border-primary pb-4 inline-block">
                                Capacidades Relacionadas
                            </h2>
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
                                {capabilities.map((cap) => (
                                    <a href={cap.link} class="group block">
                                        <div class="aspect-video bg-gray-100 mb-6 overflow-hidden">
                                            <img
                                                src={cap.image}
                                                alt={cap.title}
                                                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                            />
                                        </div>
                                        <h3 class="font-serif text-xl font-bold text-gray-900 group-hover:text-primary transition-colors flex items-center justify-between">
                                            <span>{cap.title}</span>
                                            <svg
                                                class="w-5 h-5 text-primary opacity-0 group-hover:opacity-100 transform -translate-x-2 group-hover:translate-x-0 transition-all duration-300 flex-shrink-0"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="3"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    d="M9 5l7 7-7 7"
                                                />
                                            </svg>
                                        </h3>
                                    </a>
                                ))}
                            </div>
                        </div>
                    )}
                    */}
                </div>
            </section>
        )
    }
</Layout>

<style>
    /* Estilizaciones suaves para mejorar la experiencia */
    p {
        text-wrap: pretty;
    }

    .animate-fade-in-up {
        animation: fadeInUp 0.8s ease-out forwards;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
