---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import IndustryCard from "../components/industrias/IndustryCard.astro";

import { capacidadesContent } from "../data/capacidadesContent.js";

// Dinamización Total de las 12 Capacidades
const capacidadesArray = Object.entries(capacidadesContent).map(
  ([slug, data]) => ({
    slug,
    title: data.title,
    // Utilizamos shortDescription si existe, o el intro, el primer bullet, o fallback
    description:
      data.shortDescription ||
      data.valorClienteIntro ||
      (data.valorClienteBullets &&
        data.valorClienteBullets[0] &&
        data.valorClienteBullets[0].text) ||
      "Impulsamos estrategias de desarrollo sostenible y competitividad.",
    image: data.headerImage,
    area: data.area,
    areaColor: data.areaColor,
    span: "col-span-6 md:col-span-3 lg:col-span-3", // Uniformamos columnas para un grid ordenado
  }),
);

// Orden Personalizado: Competitividad (1), Desarrollo (2), y el resto alfabético
const customOrder = ["Competitividad", "Desarrollo"];
capacidadesArray.sort((a, b) => {
  const indexA = customOrder.indexOf(a.title);
  const indexB = customOrder.indexOf(b.title);

  if (indexA !== -1 && indexB !== -1) return indexA - indexB;
  if (indexA !== -1) return -1;
  if (indexB !== -1) return 1;

  return a.title.localeCompare(b.title);
});

// Aplicar un patrón dinámico de columnas (Layout: 3, 2, 3, 2, 2) para frescura visual
const layoutPattern = [
  "col-span-6 md:col-span-3 lg:col-span-2", // Fila 1 (3 items)
  "col-span-6 md:col-span-3 lg:col-span-2",
  "col-span-6 md:col-span-3 lg:col-span-2",
  "col-span-6 md:col-span-3 lg:col-span-3", // Fila 2 (2 items)
  "col-span-6 md:col-span-3 lg:col-span-3",
  "col-span-6 md:col-span-3 lg:col-span-2", // Fila 3 (3 items)
  "col-span-6 md:col-span-3 lg:col-span-2",
  "col-span-6 md:col-span-3 lg:col-span-2",
  "col-span-6 md:col-span-3 lg:col-span-3", // Fila 4 (2 items)
  "col-span-6 md:col-span-3 lg:col-span-3",
  "col-span-6 md:col-span-3 lg:col-span-3", // Fila 5 (2 items)
  "col-span-6 md:col-span-3 lg:col-span-3",
];

capacidadesArray.forEach((item, index) => {
  item.span = layoutPattern[index] || "col-span-6 lg:col-span-3";
});

// Agrupar en tres secciones para alternar los fondos temáticos
const sections = [
  {
    bg: "bg-white",
    items: capacidadesArray.slice(0, 5), // Renderiza Fila 1 (3) y Fila 2 (2)
  },
  {
    bg: "bg-gradient-to-t from-[#e5edf5] to-[#f4f7fa]",
    items: capacidadesArray.slice(5, 10), // Renderiza Fila 3 (3) y Fila 4 (2)
  },
  {
    bg: "bg-gray-200",
    items: capacidadesArray.slice(10, 12), // Renderiza Fila 5 (2)
  },
];

const headerImage =
  "https://res.cloudinary.com/ccdcloudy/image/upload/f_auto,q_auto/v1773273741/Web%20CCD/Capacidades%20e%20Industrias/vitaly-gariev-_BHlEskTT4c-unsplash_nnbaf7.jpg";
---

<Layout title="Capacidades - CCD">
  <!-- HEADER SECTION -->
  <PageHeader title="Capacidades" backgroundImage={headerImage} />

  {
    sections.map((section) => (
      <section class={`${section.bg} py-20`}>
        <div class="container mx-auto px-6 max-w-[1600px]">
          <div class="grid grid-cols-6 gap-x-8 gap-y-16">
            {section.items.map((capacidad) => (
              <IndustryCard
                title={capacidad.title}
                description={capacidad.description}
                image={capacidad.image}
                link={`/capacidades/${capacidad.slug}`}
                colSpan={capacidad.span}
                area={capacidad.area}
                areaColor={capacidad.areaColor}
              />
            ))}
          </div>
        </div>
      </section>
    ))
  }
</Layout>
