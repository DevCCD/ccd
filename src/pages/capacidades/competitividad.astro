---
import CapabilityLayout from "../../components/capacidades/CapabilityLayout.astro";
import { teamMembers, industriesData } from "../../data/teamData";

const selectedSpecialists = [
    teamMembers["rudy-laguna"],
    teamMembers["viviana-sanchez"],
    teamMembers["elmer-huaman"],
    teamMembers["alvaro-gordillo"],
    teamMembers["karla-casas"],
    teamMembers["melissa-sanchez"],
];

const selectedIndustries = [
    industriesData["infraestructura"],
    industriesData["agroexportacion"],
    industriesData["educacion"],
    industriesData["publico"],
];

// Bento Grid Items for Generación de Valor Cliente
const valueGenerationItems = [
    {
        text: "La competitividad es el conjunto de instituciones, políticas, normas, procedimientos, interacciones y participación público y privado que determina el nivel de productividad.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772642903/Web%20CCD/Capacidades%20e%20Industrias/Competitividad/1_vssfln.jpg",
        imageAlt: "Competitividad e instituciones",
    },
    {
        text: "La productividad es la capacidad de producción de los agentes económicos como personas, empresas, organizaciones y entidades gubernamentales, dado los recursos disponibles.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772646098/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_6_jbzfbi.jpg",
        imageAlt: "Productividad y recursos",
    },
    {
        text: "La competitividad y productividad determinan el desarrollo de la zona de influencia directa e indirectamente relacionada, así como el crecimiento de los sectores económicos, cadenas de valor de bienes y servicios, clusters y el desarrollo de corredores económicos territoriales.",
        image: "/capacidades/competitividad/3.webp",
        imageAlt: "Sectores Económicos y Corredores",
    },
    {
        text: "La competitividad y productividad al impulsar las condiciones de empleabilidad y los ingresos mejora el bienestar y la calidad de vida de las personas.",
        image: "/capacidades/competitividad/5.webp",
        imageAlt: "Bienestar y Calidad de Vida",
    },
];

// Bento Grid Items for Nuestro Trabajo
const ourWorkItems = [
    {
        text: "Asesoría y asistencia técnica para mejorar la competitividad y productividad de la zona de influencia directa e indirectamente relacionada.",
        image: "/capacidades/competitividad/7.jpeg",
        imageAlt: "Asesoría zona de influencia",
    },
    {
        text: "Asesoría y asistencia técnica para mejorar la competitividad y productividad de sectores económicos, proveedores, clusters, cadenas de valor de bienes y servicios, y de corredores económicos territoriales.",
        image: "/capacidades/competitividad/6.jpg",
        imageAlt: "Asesoría sectores",
    },
    {
        text: "Asistencia técnica en planes de competitividad y productividad para regiones y países, teniendo en cuenta los determinantes:",
        bullets: [
            "Infraestructura",
            "Capital Humano",
            "Innovación",
            "Financiamiento",
            "Mercado laboral",
            "Ambiente de negocios",
            "Comercio exterior y turismo",
            "Institucionalidad",
            "Sostenibilidad ambiental",
            "Dotación de recursos naturales del subsuelo y suelo",
            "Mega y micro proyectos para mejorar la productividad"
        ],
        image: "/capacidades/competitividad/8.webp",
        imageAlt: "Planes de Competitividad",
    },
    {
        text: "Evaluar y promover actividades económicas y microclusters a niveles sectoriales y productos de alto potencial de crecimiento.",
        image: "/capacidades/competitividad/9.webp",
        imageAlt: "Evaluar clusters",
    },
    {
        text: "Diseño, creación, implementación, seguimiento y acompañamiento en iniciativas de competitividad y productividad en zonas de influencia directa e indirectamente relacionadas, para sectores y productos de alto potencial de crecimiento: comercialización, logística, transformación e industrialización y producción.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772646621/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_7_kr73ms.jpg",
        imageAlt: "Iniciativas competitividad",
    },
    {
        text: "Creación de sistemas de medición parciales e integrales para impulsar competitividad y productividad.",
        image: "/capacidades/competitividad/4.jpg",
        imageAlt: "Sistemas de medición",
    }
];

const headerImage =
    "https://res.cloudinary.com/ccdcloudy/image/upload/v1772640888/Web%20CCD/Capacidades%20e%20Industrias/Competitividad/Competitividad_inpcde.webp";
---

<CapabilityLayout
    title="Competitividad"
    description="Mejorar productividad, empleabilidad e ingresos de la población en edad de trabajar que se encuentra en la zona de influencia directa e indirectamente relacionada: comunidades, distritos, provincias, regiones, países o zonas económicas"
    headerImage={headerImage}
    valueGenerationItems={valueGenerationItems}
    ourWorkItems={ourWorkItems}
    specialists={selectedSpecialists}
    industries={selectedIndustries}
    nextCapability={{
        title: "Desarrollo",
        link: "/capacidades/desarrollo",
    }}
/>
