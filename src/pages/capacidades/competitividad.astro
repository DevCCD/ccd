---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import ValueGenerationHero from "../../components/capacidades/ValueGenerationHero.astro";
import BentoGrid from "../../components/capacidades/BentoGrid.astro";
import CapabilitySidebar from "../../components/capacidades/CapabilitySidebar.astro";

// Importamos nuestra "base de datos"
import { teamMembers, industriesData } from "../../data/teamData";

const selectedSpecialists = [
    teamMembers["rudy-laguna"],
    teamMembers["viviana-sanchez"],
    teamMembers["elmer-huaman"],
    teamMembers["alvaro-gordillo"],
    teamMembers["karla-casas"],
    teamMembers["melissa-sanchez"],
];

const selectedIndustries = [
    industriesData["infraestructura"],
    industriesData["agroexportacion"],
    industriesData["educacion"],
    industriesData["publico"],
];

// Bento Grid Items for Generación de Valor Cliente
const valueGenerationItems = [
    {
        text: "La competitividad es el conjunto de instituciones, políticas, normas y procedimientos, interacciones y participación público y privada que determinan el nivel de productividad.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772642903/Web%20CCD/Capacidades%20e%20Industrias/Competitividad/1_vssfln.jpg",
        imageAlt: "Competitividad e instituciones",
        size: "small" as const,
    },
    {
        text: "La productividad es la capacidad de producción de los agentes económicos (personas, empresas, entre otros) dados sus recursos disponibles.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772646098/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_6_jbzfbi.jpg",
        imageAlt: "Productividad y recursos",
        size: "large" as const,
    },
    {
        text: "La competitividad y productividad determinan el desarrollo de la circunscripción de interés: zona económica, multipaís, país, estado, región, provincia, distrito, comunidad y/o población.",
        image: "/capacidades/competitividad/3.webp",
        imageAlt: "Desarrollo Regional",
        size: "large" as const,
    },
    {
        text: "La competitividad y productividad determinan el crecimiento de los sectores económicos, clusters y cadenas de valor de bienes y servicios.",
        image: "/capacidades/competitividad/4.jpg",
        imageAlt: "Crecimiento de Sectores",
        size: "small" as const,
    },
    {
        text: "La competitividad y productividad al impulsar las condiciones de empleabilidad y los ingresos determinan el bienestar y la calidad de vida de la población.",
        image: "/capacidades/competitividad/5.webp",
        imageAlt: "Calidad de Vida",
        size: "wide" as const,
    },
];

// Bento Grid Items for Nuestro Trabajo
const ourWorkItems = [
    {
        text: "Asesoría y asistencia técnica en planes de competitividad y productividades para países y regiones:",
        bullets: [
            "Infraestructura",
            "Comercio Exterior y Turismo",
            "Capital Humano",
            "Institucionalidad",
            "Innovación",
            "Sostenibilidad Ambiental",
            "Financiamiento",
            "Dotación de e recursos naturales",
            "Mercado Laboral",
            "Ambiente de Negocios",
            "Mega y micro proyectos para mejorar la competitividad",
        ],
        image: "/capacidades/competitividad/8.webp",
        imageAlt: "Planes de Competitividad",
        size: "wide" as const,
    },
    {
        text: "Asesoría y asistencia técnica para mejorar la competitividad y productividad para circunscripción de interés: zona económica, multipaís, país, estado, región, provincia, distrito, comunidad y/o población, así como de sectores económicos, empresarial y proveedores, clusters y cadenas de valor de bienes y servicios.",
        image: "/capacidades/competitividad/7.jpeg",
        imageAlt: "Asesoría Competitividad",
        size: "medium" as const,
    },

    {
        text: "Creación de sistemas de medición parciales e integrales para impulsar competitividad y productividad.",
        image: "/capacidades/competitividad/6.jpg",
        imageAlt: "Sistemas de Medición",
        size: "small" as const,
    },
    {
        text: "Evaluar y promover actividades económicas y clusters, microclusters a niveles sectoriales y productos de alto potencial de crecimiento.",
        image: "/capacidades/competitividad/9.webp",
        imageAlt: "Promoción de Clusters",
        size: "small" as const,
    },
    {
        text: "Diseño, creación, implementación, seguimiento y acompañamiento en iniciativas integrales y parciales de competitividad y productividad para áreas de influencia directa e indirecta, a niveles de sectores y productos de alto potencial de crecimiento: comercialización, logística, transformación e industrialización y producción.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772646621/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_7_kr73ms.jpg",
        imageAlt: "Iniciativas Integrales",
        size: "medium" as const,
    },
];

const headerImage =
    "https://res.cloudinary.com/ccdcloudy/image/upload/v1772640888/Web%20CCD/Capacidades%20e%20Industrias/Competitividad/Competitividad_inpcde.webp";
---

<Layout
    title="Competitividad - CCD"
    description="Mejoramos la competitividad y productividad para impulsar el desarrollo, empleabilidad e ingresos en diversas circunscripciones y sectores económicos."
>
    <PageHeader title="Competitividad" backgroundImage={headerImage} />

    <section class="bg-white">
        <div class="container mx-auto px-6 lg:px-12 py-16 md:py-24">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
                <!-- CONTENIDO PRINCIPAL (9 columnas) -->
                <div class="lg:col-span-9 space-y-24">
                    <!-- ============================================== -->
                    <!-- SECCIÓN 1: GENERACIÓN DE VALOR CLIENTE         -->
                    <!-- ============================================== -->
                    <div class="space-y-12">
                        <ValueGenerationHero
                            title="Generación de Valor Cliente"
                            description="Mejorar productividad, empleabilidad e ingresos de la Población en Edad de Trabajar (PET) de circunscripción directa e indirectamente relacionada: zona económica, multipaís, país, estado, región, provincia, distrito, comunidad y/o población directa e indirectamente relacionada."
                        />

                        <BentoGrid items={valueGenerationItems} />
                    </div>

                    <!-- ============================================== -->
                    <!-- SECCIÓN 2: NUESTRO TRABAJO                     -->
                    <!-- ============================================== -->
                    <div
                        id="nuestro-trabajo"
                        class="scroll-mt-24 space-y-12 pt-12 border-t border-gray-200"
                    >
                        <div class="text-center md:text-left">
                            <h2
                                class="font-serif text-3xl md:text-4xl font-bold text-gray-900 mb-4"
                            >
                                Nuestro{" "}
                                <span class="text-primary italic">
                                    Trabajo
                                </span>
                            </h2>
                        </div>

                        <BentoGrid items={ourWorkItems} />

                        <!-- Siguiente Capacidad -->
                        <div class="pt-12">
                            <a
                                href="/capacidades/desarrollo"
                                class="group flex items-center justify-between p-8 rounded-2xl bg-gray-50 border border-gray-100 hover:border-primary/30 transition-all"
                            >
                                <div>
                                    <span
                                        class="text-sm font-bold text-primary uppercase tracking-widest"
                                        >Siguiente Capacidad</span
                                    >
                                    <h4
                                        class="text-2xl font-serif font-bold text-gray-900 mt-2"
                                    >
                                        Desarrollo
                                    </h4>
                                </div>
                                <div
                                    class="w-12 h-12 rounded-full bg-white border border-gray-200 flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-6 w-6"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- COLUMNA DERECHA: SIDEBAR (3/12) -->
                <CapabilitySidebar
                    specialists={selectedSpecialists}
                    industries={selectedIndustries}
                />
            </div>
        </div>
    </section>
</Layout>
