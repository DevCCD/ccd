---
import CapabilityLayout from "../../components/capacidades/CapabilityLayout.astro";
import { teamMembers, industriesData } from "../../data/teamData";

const selectedSpecialists = [
    teamMembers["alvaro-gordillo"],
    teamMembers["rudy-laguna"],
    teamMembers["alex-carbajal"],
    teamMembers["karla-casas"],
    teamMembers["jorge-ruiz"],
];

const selectedIndustries = [
    industriesData["mineria"],
    industriesData["portuarios"],
    industriesData["agroexportacion"],
];

// Bento Grid Items for Generación de Valor Cliente
const valueGenerationItems = [
    {
        text: "Visión de prosperidad: Multi Regional / Provincial / Distrital / Comunal.",
        image: "/capacidades/corredores/aerial-view-pastoruri-glacier-ancash-peru.jpg",
        imageAlt: "Visión de Prosperidad",
        size: "small" as const,
    },
    {
        text: "Mayor movilidad y oportunidades de educación, salud y empleo para la población.",
        image: "/capacidades/corredores/Antamina operaciones_0.jpg",
        imageAlt: "Mayor Movilidad",
        size: "small" as const,
    },
    {
        text: "Potencia la productividad y el desarrollo de clusters.",
        image: "/capacidades/corredores/palccoyo-rainbow-mountains-near-cusco-peru.jpg",
        imageAlt: "Desarrollo Integrado",
        size: "small" as const,
    },
    {
        text: "Desarrollo integrado del área de influencia o de más de una circunscripción territorial: países, regiones, provincias, distritos y/o comunidades.",
        image: "/capacidades/corredores/pesca-1.jpg",
        imageAlt: "Ordenamiento Geopolítico",
        size: "medium" as const,
    },
    {
        text: "Cubre vacíos existentes en el ordenamiento geopolítico y acelera el desarrollo y la competitividad.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772645450/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_3_atyhly.jpg",
        imageAlt: "Productividad",
        size: "small" as const,
    },
    {
        text: "Robustece el desarrollo bajo el enfoque territorial.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1770859894/Web%20CCD/Corporate%20Flat%20Illustration/corredores_fmafpv.jpg",
        imageAlt: "Ordenamiento Geopolítico",
        size: "small" as const,
    },
    {
        text: "Potencia el proceso de desarrollo de la población relacionada al Corredor Económico Territorial.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772651018/Web%20CCD/Capacidades%20e%20Industrias/Corredores/corredores_tren_acembc.png",
        imageAlt: "Productividad",
        size: "medium" as const,
    },
];

// Bento Grid Items for Nuestro Trabajo
const ourWorkItems = [
    {
        text: "Elaboración de estudios metodológicos para la constitución, gobernanza, planeamiento y gestión con actores público - privado claves en la formación, consolidación y crecimiento de Corredores Económicos Territoriales.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772651016/Web%20CCD/Capacidades%20e%20Industrias/Corredores/Corredor-logistico_yold3l.webp",
        imageAlt: "Estudios Metodológicos",
        size: "wide" as const,
    },
    {
        text: "Megaproyectos e proyectos de desarrollo para potenciar el impacto en el cierre de brechas y desarrollo de la población del Corredor Económico Territorial.",
        image: "/capacidades/corredores/corredores.jpg",
        imageAlt: "Megaproyectos",
        size: "medium" as const,
    },
    {
        text: "KPI y sistema de datos e información digital de Corredores Económicos Territoriales.",
        image: "/capacidades/corredores/kpi.jpg",
        imageAlt: "Sistemas de Datos",
        size: "small" as const,
    },
];

const headerImage =
    "https://res.cloudinary.com/ccdcloudy/image/upload/v1772641842/Web%20CCD/Capacidades%20e%20Industrias/Corredores/Corredores_wctx4s.webp";
---

<CapabilityLayout
    title="Corredores Económicos Territoriales"
    description="Diseñamos planes viables de Corredores Económicos Territoriales desde el enfoque de desarrollo, alineando visiones compartidas, generando confianza e integrando proyectos."
    headerImage={headerImage}
    valueGenerationItems={valueGenerationItems}
    ourWorkItems={ourWorkItems}
    specialists={selectedSpecialists}
    industries={selectedIndustries}
    nextCapability={{
        title: "Inversiones y Proyectos de Desarrollo",
        link: "/capacidades/inversiones",
    }}
/>
