---
import CapabilityLayout from "../../components/capacidades/CapabilityLayout.astro";
import { capacidadesContent } from "../../data/capacidadesContent.js";

const data = capacidadesContent["desarrollo"];

// Extraemos datos necesarios para el layout base
const { nuestroTrabajo, ...layoutData } = data;

const pilaresDesarrollo = [
    {
        label: "Sociodemográfica",
        icon: "https://res.cloudinary.com/ccdcloudy/image/upload/f_auto,q_auto/v1778772399/Web%20CCD/Iconos/Capacidades/Sociodemo_mc32wp.png",
    },
    {
        label: "Económica",
        icon: "https://res.cloudinary.com/ccdcloudy/image/upload/f_auto,q_auto/v1778772495/Web%20CCD/Iconos/Capacidades/economico_odrhef.png",
    },
    {
        label: "Conectividad",
        icon: "https://res.cloudinary.com/ccdcloudy/image/upload/f_auto,q_auto/v1778772423/Web%20CCD/Iconos/Capacidades/conectividad_mnqpxy.png",
    },
    {
        label: "Gobernanza",
        icon: "https://res.cloudinary.com/ccdcloudy/image/upload/f_auto,q_auto/v1778772496/Web%20CCD/Iconos/Capacidades/gobernanza_pj8fwq.png",
    },
    {
        label: "Riesgos y desastres",
        icon: "https://res.cloudinary.com/ccdcloudy/image/upload/f_auto,q_auto/v1778772497/Web%20CCD/Iconos/Capacidades/riesgos_dyanqn.png",
    },
    {
        label: "Ambiental",
        icon: "https://res.cloudinary.com/ccdcloudy/image/upload/f_auto,q_auto/v1778772399/Web%20CCD/Iconos/Capacidades/ambiental_l3s0dn.png",
    },
];

const alcancesDesarrollo = [
    {
        label: "Zona de influencia directa e indirectamente relacionada",
        level: 6,
    },
    { label: "Región", level: 5 },
    { label: "Provincia", level: 4 },
    { label: "Distrito", level: 3 },
    { label: "Comunidad, localidad o caserío", level: 2 },
    { label: "Zonas de reasentamiento poblacional", level: 1 },
];
---

<CapabilityLayout {...layoutData}>
    <!-- ===== NUESTRO TRABAJO — DESARROLLO (Diseño Manual Premium) ===== -->
    <section
        class="relative bg-gradient-to-br from-primary via-[#6a0016] to-[#2a0008] pt-24 md:pt-32 pb-0"
        id="nuestro-trabajo"
    >
        <!-- Ruido de textura sutil -->
        <div
            class="absolute inset-0 opacity-[0.03] bg-[url('data:image/svg+xml;base64,')] pointer-events-none"
        >
        </div>

        <div
            class="container mx-auto px-6 lg:px-12 max-w-[1600px] relative z-10"
        >
            <!-- Título de Sección -->
            <div
                class="mb-14 flex flex-col items-center md:items-start text-center md:text-left nt-title"
            >
                <h2
                    class="font-serif text-3xl md:text-5xl font-black text-white mb-5 tracking-tight"
                >
                    Capacidades CCD
                </h2>
                <div class="w-24 h-[5px] bg-secondary"></div>
            </div>

            <!-- ============================================================ -->
            <!-- TARJETA DESTACADA — Planes Concertados                       -->
            <!-- ============================================================ -->
            <div
                class="featured-card group bg-white overflow-hidden shadow-2xl mb-10 md:mb-14 flex flex-col lg:flex-row min-h-[460px] md:min-h-[520px]"
            >
                <!-- Imagen dominante -->
                <div
                    class="relative overflow-hidden w-full lg:w-[60%] min-h-[300px] lg:min-h-full shrink-0"
                >
                    <img loading="lazy"
                        src="https://res.cloudinary.com/ccdcloudy/image/upload/q_auto/f_auto/v1776445891/Web%20CCD/Capacidades%20e%20Industrias/Desarrollo/Imagen2_vk4ehy.png"
                        alt="Planes Concertados — Desarrollo"
                        class="absolute inset-0 w-full h-full object-cover transition-transform duration-[4000ms] ease-in-out group-hover:scale-[1.04]"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-r from-black/20 via-transparent to-transparent pointer-events-none"
                    >
                    </div>
                </div>

                <!-- Contenido -->
                <div
                    class="flex flex-col justify-center p-10 md:p-14 lg:p-16 flex-grow border-t-4 border-primary lg:border-t-0 lg:border-l-4"
                >
                    <h3
                        class="font-serif text-4xl md:text-5xl lg:text-6xl font-black text-primary leading-[1.1] mb-6 tracking-tight"
                    >
                        Planes de Desarrollo Concertados
                    </h3>
                    <p
                        class="font-sans text-lg md:text-xl text-gray-500 leading-relaxed max-w-lg"
                    >
                        Asistencia técnica en la elaboración de planes
                        territoriales de desarrollo concertados, teniendo en
                        cuenta las siguientes dimensiones clave.
                    </p>
                    <div class="mt-8 w-16 h-1 bg-secondary"></div>
                </div>
            </div>
        </div>

        <!-- ============================================================ -->
        <!-- SECCIÓN EJES ESTRATÉGICOS — Asistencia Técnica (Ejes)        -->
        <!-- ============================================================ -->
        <div
            class="axes-section py-20 md:py-28 mt-0 bg-[#e8f1f8] relative overflow-hidden border-y border-blue-100/50"
        >
            <!-- Patrón de cuadrícula técnica sutil -->
            <div
                class="absolute inset-0 opacity-[0.05] pointer-events-none"
                style="background-image: linear-gradient(#1e3a8a 1px, transparent 1px), linear-gradient(90deg, #1e3a8a 1px, transparent 1px); background-size: 50px 50px;"
            >
            </div>

            <div
                class="container mx-auto px-6 lg:px-12 max-w-[1440px] relative z-10"
            >
                <div class="relative flex flex-col items-center">
                    <!-- Hub Central Corporativo -->
                    <div
                        class="hidden lg:flex absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 bg-primary/50 rounded-full border-[8px] border-white shadow-[0_0_40px_rgba(145,1,33,0.25)] items-center justify-center z-20 transition-transform duration-500 hover:scale-105"
                    >
                        <div class="text-center">
                            <span
                                class="block font-serif text-3xl font-black text-white tracking-tight"
                                >Desarrollo</span
                            >
                            <div class="w-10 h-1 bg-white/40 mx-auto mt-2"></div>
                        </div>
                    </div>

                    <!-- Layout de Ejes (2 Columnas) -->
                    <div
                        class="grid grid-cols-1 lg:grid-cols-2 gap-x-60 gap-y-10 w-full relative"
                    >
                        <!-- Columna Izquierda -->
                        <div class="space-y-6">
                            {
                                pilaresDesarrollo.slice(0, 3).map((p) => (
                                    <div class="axis-card group flex items-center gap-6 p-6 bg-white border border-gray-100 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-secondary/30 relative">
                                        <div class="w-16 h-16 flex items-center justify-center shrink-0">
                                            <img loading="lazy" src={p.icon} alt={p.label} class="w-full h-full object-contain" />
                                        </div>
                                        <div class="flex-grow">
                                            <h4 class="font-sans text-2xl font-bold text-gray-900">
                                                {p.label}
                                            </h4>
                                            <div class="w-40 h-0.5 bg-gray-200 mt-2 group-hover:w-40 group-hover:bg-secondary/50 transition-all" />
                                        </div>
                                    </div>
                                ))
                            }
                        </div>

                        <!-- Columna Derecha -->
                        <div class="space-y-6">
                            {
                                pilaresDesarrollo.slice(3, 6).map((p) => (
                                    <div class="axis-card group flex items-center lg:flex-row-reverse gap-6 p-6 bg-white border border-gray-100 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-secondary/30 relative text-left lg:text-right">
                                        <div class="w-16 h-16 flex items-center justify-center shrink-0">
                                            <img loading="lazy" src={p.icon} alt={p.label} class="w-full h-full object-contain" />
                                        </div>
                                        <div class="flex-grow">
                                            <h4 class="font-sans text-2xl font-bold text-gray-900">
                                                {p.label}
                                            </h4>
                                            <div class="w-40 h-0.5 bg-gray-200 mt-2 ml-auto group-hover:w-40 group-hover:bg-secondary/50 transition-all" />
                                        </div>
                                    </div>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ============================================================ -->
        <!-- SECCIÓN ALCANCES — Gráfico Circular Exacto                   -->
        <!-- ============================================================ -->
        <div class="scope-exact-section py-20 md:py-32 bg-gray-50 relative overflow-hidden">
            <div class="container mx-auto px-6 lg:px-12 max-w-[1400px] relative">
                
                <!-- Título -->
                <div class="text-center mb-16 md:mb-24">
                    <h3 class="font-serif text-3xl md:text-5xl font-black text-gray-900 tracking-tight">
                        Alcances de los Planes de Desarrollo Concertados
                    </h3>
                </div>

                <div class="flex justify-center w-full relative">
                    <!-- Contenedor responsivo para el SVG -->
                    <div class="w-full max-w-[1100px] overflow-visible">
                        <svg class="w-full h-auto overflow-visible" viewBox="0 0 1100 560" preserveAspectRatio="xMinYMid meet">
                            <defs>
                                <filter id="glow-core" x="-20%" y="-20%" width="140%" height="140%">
                                    <feGaussianBlur stdDeviation="6" result="blur" />
                                    <feComposite in="SourceGraphic" in2="blur" operator="over" />
                                </filter>
                            </defs>

                            <!-- CÍRCULOS CONCÉNTRICOS -->
                            <g class="circles">
                                <circle cx="300" cy="300" r="260" fill="#007C8D" class="c-0 transition-all duration-300" />
                                <circle cx="300" cy="300" r="215" fill="#00918E" class="c-1 transition-all duration-300" />
                                <circle cx="300" cy="300" r="170" fill="#00ACC2" class="c-2 transition-all duration-300" />
                                <circle cx="300" cy="300" r="125" fill="#00C5C0" class="c-3 transition-all duration-300" />
                                <circle cx="300" cy="300" r="80" fill="#73E2FF" class="c-4 transition-all duration-300" />
                                <!-- Core -->
                                <circle cx="300" cy="300" r="35" fill="#007C8D" filter="url(#glow-core)" class="c-5 transition-all duration-500" />
                            </g>

                            <!-- ITEMS CON HOVER GLOBAL -->
                            {alcancesDesarrollo.map((item, idx) => {
                                // Puntos de nacimiento en los círculos
                                const arrDotY = [65, 110, 155, 200, 245, 300];
                                const dotY = arrDotY[idx];
                                
                                // Posiciones de texto separadas y balanceadas
                                const textY = 65 + (idx * 80);
                                const dy = textY - dotY;
                                
                                // Path en formato "escalera" a ~45 grados
                                const pathD = `M300 ${dotY} L360 ${dotY} L${360 + dy} ${textY} L560 ${textY}`;
                                
                                return (
                                    <g class="alcance-group cursor-default" data-index={idx}>
                                        <!-- Línea conectora acodada -->
                                        <path 
                                            d={pathD} 
                                            stroke="white" 
                                            stroke-width="2.5" 
                                            fill="none" 
                                            class="conn-line transition-all duration-300" 
                                            stroke-linejoin="round"
                                            style="filter: drop-shadow(0 2px 3px rgba(0,0,0,0.4));"
                                        />
                                        
                                        <!-- Punto de origen -->
                                        <circle 
                                            cx="300" 
                                            cy={dotY} 
                                            r="6" 
                                            fill="white" 
                                            class="conn-dot transition-all duration-300"
                                            style="filter: drop-shadow(0 2px 3px rgba(0,0,0,0.4));"
                                        />
                                        
                                        <!-- Texto incrustado (altura extendida para envolver multilinea sin cortarse) -->
                                        <foreignObject x="580" y={textY - 40} width="520" height="80">
                                            <div xmlns="http://www.w3.org/1999/xhtml" class="w-full h-full flex items-center">
                                                <h4 class="font-sans text-[18px] lg:text-[21px] font-bold text-gray-500 transition-all duration-300 hover-text leading-tight w-full pr-4">
                                                    {item.label}
                                                </h4>
                                            </div>
                                        </foreignObject>
                                    </g>
                                );
                            })}
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <style>
            /* Hover States on the Group */
            .alcance-group:hover .conn-line {
                stroke: white;
                stroke-width: 4px;
                opacity: 1;
            }
            .alcance-group:hover .conn-dot {
                fill: white;
                r: 9px;
                filter: drop-shadow(0 0 5px rgba(255,255,255,0.5));
            }
            .alcance-group:hover .hover-text {
                color: #007C8D;
                transform: translateX(10px);
                font-size: 1.15em;
            }
            
            /* Visual feedback para los círculos */
            .circle-active-0, .circle-active-1, .circle-active-2, .circle-active-3, .circle-active-4 { 
                filter: brightness(1.1) contrast(1.1);
                stroke: white;
                stroke-width: 3px;
            }
            .circle-active-5 { transform: scale(1.2); transform-origin: 300px 300px; filter: brightness(1.2); }
        </style>

        <script is:inline>
            document.addEventListener('DOMContentLoaded', () => {
                const groups = document.querySelectorAll('.alcance-group');
                const circlesEl = [];
                for(let i=0; i<=5; i++) {
                    circlesEl.push(document.querySelector('.c-' + i));
                }

                groups.forEach(g => {
                    g.addEventListener('mouseenter', () => {
                        const idx = parseInt(g.getAttribute('data-index'));
                        const circle = circlesEl[idx];
                        if (circle) circle.classList.add(`circle-active-${idx}`);
                    });
                    g.addEventListener('mouseleave', () => {
                        const idx = parseInt(g.getAttribute('data-index'));
                        const circle = circlesEl[idx];
                        if (circle) circle.classList.remove(`circle-active-${idx}`);
                    });
                });
            });
        </script>

        <!-- ============================================================ -->
        <!-- SECCIÓN 2 COLUMNAS — Sistemas KPIs & Proyectos Educativos    -->
        <!-- ============================================================ -->
        <div class="bg-black/10 backdrop-blur-sm py-16 md:py-24">
            <div class="container mx-auto px-6 lg:px-12 max-w-[1600px]">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
                    <!-- Tarjeta A: Sistemas KPIs -->
                    <div
                        class="grid-card group bg-white shadow-md hover:shadow-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1.5 flex flex-col h-full"
                    >
                        <div
                            class="relative h-[340px] overflow-hidden bg-gray-100 shrink-0"
                        >
                            <img loading="lazy"
                                src="https://res.cloudinary.com/ccdcloudy/image/upload/f_auto,q_auto/v1770857524/Web%20CCD/Corporate%20Flat%20Illustration/planes_de_desarrollo2_tb0bj3.jpg"
                                alt="Sistemas KPIs"
                                class="w-full h-full object-cover transition-transform duration-[2500ms] group-hover:scale-[1.07]"
                            />
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"
                            >
                            </div>
                        </div>
                        <div class="p-8 lg:p-10 flex flex-col flex-grow">
                            <h3
                                class="font-sans text-xl md:text-2xl font-bold text-gray-900 mb-4 group-hover:text-primary transition-colors duration-300 leading-tight"
                            >
                                Sistemas KPIs
                            </h3>
                            <p
                                class="font-sans text-base text-gray-500 leading-relaxed"
                            >
                                Creación de sistemas de medición y KPIs para el
                                desarrollo de zonas de influencia directa e
                                indirectamente relacionadas.
                            </p>
                        </div>
                    </div>

                    <!-- Tarjeta B: Proyectos Educativos -->
                    <div
                        class="grid-card group bg-white shadow-md hover:shadow-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1.5 flex flex-col h-full"
                    >
                        <div
                            class="relative h-[340px] overflow-hidden bg-gray-100 shrink-0"
                        >
                            <img loading="lazy"
                                src="https://res.cloudinary.com/ccdcloudy/image/upload/f_auto,q_auto/v1774880236/Web%20CCD/Capacidades%20e%20Industrias/Desarrollo/InstitucionEducativaIntegrada_hzma4b.png"
                                alt="Proyectos Educativos"
                                class="w-full h-full object-cover transition-transform duration-[2500ms] group-hover:scale-[1.07]"
                            />
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"
                            >
                            </div>
                        </div>
                        <div class="p-8 lg:p-10 flex flex-col flex-grow">
                            <h3
                                class="font-sans text-xl md:text-2xl font-bold text-gray-900 mb-4 group-hover:text-primary transition-colors duration-300 leading-tight"
                            >
                                Proyectos Educativos
                            </h3>
                            <p
                                class="font-sans text-base text-gray-500 leading-relaxed"
                            >
                                Diseñar e implementar proyectos para mejorar la
                                educación en niveles básico regular, técnico y
                                universitario.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</CapabilityLayout>

<style>
    .nt-title {
        animation: fadeSlideUp 0.7s ease-out both;
    }
    .featured-card {
        animation: fadeSlideUp 0.8s ease-out 0.2s both;
    }
    .axis-card {
        animation: fadeSlideUp 0.6s ease-out both;
    }
    .grid-card {
        animation: fadeSlideUp 0.6s ease-out both;
    }

    @keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Estética Corporativa para la sección de ejes */
    .axes-section {
        position: relative;
    }

    /* Estética Corporativa para la sección de ejes */
    .axes-section {
        position: relative;
    }
</style>
