---
import CapabilityLayout from "../../components/capacidades/CapabilityLayout.astro";
import { teamMembers, industriesData } from "../../data/teamData";

const selectedSpecialists = [
    teamMembers["alex-carbajal"],
    teamMembers["fernando-jauregui"],
    teamMembers["rudy-laguna"],
    teamMembers["alvaro-gordillo"],
    teamMembers["mario-huaman"],
    teamMembers["jorge-ruiz"],
];

const selectedIndustries = [
    industriesData["hidrocarburos"],
    industriesData["agropecuario"],
    industriesData["infraestructura"],
];

// Bento Grid Items for Generación de Valor Cliente
const valueGenerationItems = [
    {
        text: "Mejorar las condiciones de vida de las personas: educación universal, caminos transitables, calidad de la atención de la salud, buen gobierno y aumentar ingresos.",
        image: "/capacidades/desarrollo/InstitucionEducativaIntegrada.png",
        imageAlt: "Mejora de Condiciones",
        size: "large" as const,
    },
    {
        text: "Promover la competitividad mediante el cierre de brechas, mejorando el bienestar económico y social de las personas.",
        image: "/capacidades/desarrollo/internet 1.jpg",
        imageAlt: "Cierre de Brechas",
        size: "small" as const,
    },
    {
        text: "Crear riqueza a fin de mantener la prosperidad o bienestar económico y social de los habitantes.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772646882/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_8_lfecbm.jpg",
        imageAlt: "Prosperidad Económica",
        size: "wide" as const,
    },
];

// Bento Grid Items for Nuestro Trabajo
const ourWorkItems = [
    {
        text: "Brindar asistencia técnica en la implementación, seguimiento y monitoreo de planes de desarrollo:",
        bullets: [
            "Sociodemográfico",
            "Crecimiento económico",
            "Conectividad",
            "Ambiental",
            "Riesgos y desastres",
            "Gobernanza",
        ],
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772647317/Web%20CCD/Capacidades%20e%20Industrias/Desarrollo/desarrollo_oqsn7d.jpg",
        imageAlt: "Planes de Competitividad",
        size: "wide" as const,
    },

    {
        text: "Identificar, diseñar, asesorar y asistencia técnica para promover y desarrollar corredores económicos territoriales a escala nacional, regional, local y comunal.",
        image: "/capacidades/desarrollo/Antamina operaciones_0.jpg",
        imageAlt: "Seguimiento",
        size: "medium" as const,
    },
    {
        text: "Elaborar e implementar planes de inversión para el desarrollo de corredores económicos territoriales.",
        image: "/capacidades/desarrollo/palta.png",
        imageAlt: "Inversiones",
        size: "small" as const,
    },

    {
        text: "Elaborar e implementar planes estratégicos y de inversión para el desarrollo de zonas de influencia directa e indirecta.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772645206/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_nvqir5.jpg",
        imageAlt: "Inversiones",
        size: "small" as const,
    },

    {
        text: "Asesoría y asistencia técnica en el planeamiento y la gestión de los proyectos de inversión social de los fondos sociales.",
        image: "/capacidades/desarrollo/evaluacion3.jpg",
        imageAlt: "Planes de Desarrollo",
        size: "small" as const,
    },
    {
        text: "Asesoría y asistencia técnica en el planeamiento y la gestión de proyectos de inversión social de los fondos sociales para el desarrollo.",
        image: "/capacidades/corredores/APLCMEZPQZBZ3OIEJQMS5TLVYQ.jpg",
        imageAlt: "Planes de Desarrollo",
        size: "small" as const,
    },

    {
        text: "Creación de sistemas de medición integrales, parciales y KPIs (Key Performance Indicators) para el desarrollo de circunscripciones país, estado, región, provincia, distrito, comunidad, localidad y caserío.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772647752/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_9_rnzit5.jpg",
        imageAlt: "Planes de Desarrollo",
        size: "wide" as const,
    },
    {
        text: "Diseñar e implementar proyectos para mejorar la educación en niveles básico regular, técnico y universitario.",
        image: "/capacidades/desarrollo/IMG_1050.JPG",
        imageAlt: "Planes de Desarrollo",
        size: "medium" as const,
    },
    {
        text: "Diseño, creación e implementación de metodologías para el desarrollo a circunscripciones concretas.",
        image: "/capacidades/desarrollo/Truchas en Huancané.jpg",
        imageAlt: "Planes de Desarrollo",
        size: "small" as const,
    },
];

const headerImage =
    "https://res.cloudinary.com/ccdcloudy/image/upload/v1772640288/Web%20CCD/Capacidades%20e%20Industrias/Desarrollo/Desarrollo_xepqfz.webp";
---

<CapabilityLayout
    title="Desarrollo"
    description="Mejorar la calidad de vida de las personas de manera integral, para circunscripciones: país, estado, región, provincia, distrito y comunidad."
    headerImage={headerImage}
    valueGenerationItems={valueGenerationItems}
    ourWorkItems={ourWorkItems}
    specialists={selectedSpecialists}
    industries={selectedIndustries}
    nextCapability={{
        title: "Fortalecimiento de Capacidades y Capital Humano",
        link: "/capacidades/fortalecimiento",
    }}
>
    <!-- Slot para contenido antes de Nuestro Trabajo -->
    <div
        slot="before-work"
        class="bg-gradient-to-br from-gray-50 to-white rounded-3xl p-8 md:p-12 border border-gray-200 shadow-sm mb-12"
    >
        <h4
            class="font-serif text-2xl font-bold text-gray-900 mb-8 pb-4 border-b border-gray-200"
        >
            Elaborar planes y estudios de Desarrollo:
        </h4>
        <ul
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-x-8 gap-y-5"
        >
            {
                [
                    "Concertado de ámbitos regional, provincial y distrital.",
                    "Territorial de comunidades, localidades y caseríos.",
                    "Territorial en contextos de reasentamiento poblacional.",
                    "Territorial para áreas de influencia directa e indirecta.",
                ].map((item) => (
                    <li class="flex items-start group">
                        <span class="w-2 h-2 rounded-full bg-primary mt-2 mr-3 flex-shrink-0 group-hover:scale-150 transition-transform" />
                        <span class="text-gray-700 font-medium text-base group-hover:text-primary transition-colors">
                            {item}
                        </span>
                    </li>
                ))
            }
        </ul>
    </div>
</CapabilityLayout>
