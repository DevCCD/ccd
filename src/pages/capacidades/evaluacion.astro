---
import CapabilityLayout from "../../components/capacidades/CapabilityLayout.astro";
import { teamMembers, industriesData } from "../../data/teamData";

const selectedSpecialists = [
    teamMembers["fernando-jauregui"],
    teamMembers["rudy-laguna"],
    teamMembers["alvaro-gordillo"],
    teamMembers["alex-carbajal"],
    teamMembers["karla-casas"],
    teamMembers["melissa-sanchez"],
];

const selectedIndustries = [
    industriesData["agropecuario"],
    industriesData["educacion"],
    industriesData["publico"],
];

// Bento Grid Items for Generación de Valor Cliente
const valueGenerationItems = [
    {
        text: "Optimización e integridad vertical y horizontal de la inversión social desde la Negociación, Aprobación y Elaboración de estudios hasta su Implementación, Operación y Mantenimiento.",
        image: "/capacidades/evaluacion de proyectos/antamina.jpg",
        imageAlt: "Eficacia e Impacto",
        size: "small" as const,
    },
    {
        text: "Generamos transparencia, ganancias de eficiencias y reportes para Accionistas, Directorio, Población beneficiaria y Líderes comunales, reflejados en Anuarios y Documentos de sostenibilidad.",
        image: "/capacidades/evaluacion de proyectos/evaluacion3.jpg",
        imageAlt: "Sostenibilidad",
        size: "medium" as const,
    },
    {
        text: "Generación de complementariedad con intervenciones público y privadas en Inversión, Fondeo y Operación y mantenimiento.",
        image: "/capacidades/evaluacion de proyectos/evaluacion2.jpg",
        imageAlt: "Evaluación Ex Ante",
        size: "small" as const,
    },
    {
        text: "Optimizamos decisiones sobre intervenciones sociales para el desarrollo mediante Potenciación, Restructuración y Culminación.",
        image: "/capacidades/evaluacion de proyectos/open_pit_Barrick-Gold-Mine-e1493577591276-960x480.jpg",
        imageAlt: "Evaluación Ex Post",
        size: "medium" as const,
    },
];

// Bento Grid Items for Nuestro Trabajo
const ourWorkItems = [
    {
        text: "Evaluamos proyectos y programas de inversión social en sus etapas ExAnte, ExDure y ExPost.",
        image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&h=600&fit=crop",
        imageAlt: "Impacto",
        size: "small" as const,
    },
    {
        text: "Participación de los stakeholders de los programas y proyectos en el proceso de evaluación.",
        image: "/capacidades/evaluacion de proyectos/marco.jpg",
        imageAlt: "Planificación",
        size: "medium" as const,
    },
    {
        text: "Presentación de resultados de la evaluación a Stakeholders.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772645346/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_1_qzpwtu.jpg",
        imageAlt: "Monitoreo",
        size: "small" as const,
    },
    {
        text: "Cuantificación de impactos.",
        image: "/capacidades/fondos/monitoreo.jpg",
        imageAlt: "Monitoreo",
        size: "small" as const,
    },
    {
        text: "Implementación de recomendaciones de la evaluación en todas las áreas de la institución.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1770857524/Web%20CCD/Corporate%20Flat%20Illustration/planes_de_desarrollo2_tb0bj3.jpg",
        imageAlt: "Monitoreo",
        size: "small" as const,
    },
];

const headerImage =
    "https://res.cloudinary.com/ccdcloudy/image/upload/v1772641630/Web%20CCD/Capacidades%20e%20Industrias/Evaluaci%C3%B3n%20de%20Programas/Evaluacion_paq2ri.webp";
---

<CapabilityLayout
    title="Evaluación de Programas y Proyectos"
    description="Aseguramos mayores calidad y rendimientos de la inversión social en el área de influencia mediante Improvement, Accountability y Enlightenment."
    headerImage={headerImage}
    valueGenerationItems={valueGenerationItems}
    ourWorkItems={ourWorkItems}
    specialists={selectedSpecialists}
    industries={selectedIndustries}
    nextCapability={{
        title: "Corredores Económicos Territoriales",
        link: "/capacidades/corredores",
    }}
>
    <!-- Slot para contenido antes de Nuestro Trabajo -->
    <div
        slot="before-work"
        class="bg-gradient-to-br from-gray-50 to-white rounded-3xl p-8 md:p-12 border border-gray-200 shadow-sm mb-12"
    >
        <h4
            class="font-serif text-2xl font-bold text-gray-900 mb-8 pb-4 border-b border-gray-200"
        >
            Evaluación cualitativo y cuantitativo integral de programas y
            proyectos de inversión:
        </h4>
        <ul
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-5"
        >
            {
                [
                    "Pertinencia",
                    "Eficiencia",
                    "Eficacia",
                    "Impacto",
                    "Sostenibilidad",
                ].map((item) => (
                    <li class="flex items-start group">
                        <span class="w-2 h-2 rounded-full bg-primary mt-2 mr-3 flex-shrink-0 group-hover:scale-150 transition-transform" />
                        <span class="text-gray-700 font-medium text-base group-hover:text-primary transition-colors">
                            {item}
                        </span>
                    </li>
                ))
            }
        </ul>
    </div>
</CapabilityLayout>
