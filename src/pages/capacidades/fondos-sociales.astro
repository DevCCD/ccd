---
import CapabilityLayout from "../../components/capacidades/CapabilityLayout.astro";
import { capacidadesContent } from "../../data/capacidadesContent.js";

const data = capacidadesContent["fondos-sociales"];

// Extraemos datos necesarios para el layout base
const { nuestroTrabajo, ...layoutData } = data;

// Reorganizamos según pedido del usuario:
// Fila 1 (2 cols): Creación de Fondos Sociales (6) y Asistencia Técnica (0)
const row1 = [nuestroTrabajo[6], nuestroTrabajo[0]];
// Fila 2 (2 cols): Optimizar Procesos (2) y Optimizar Procesos en Fondos Sociales (5)
const row2 = [nuestroTrabajo[2], nuestroTrabajo[5]];
// Fila 3 (3 cols): El resto (1, 3, 4)
const row3 = [nuestroTrabajo[1], nuestroTrabajo[3], nuestroTrabajo[4]];
---

<CapabilityLayout {...layoutData}>
    <!-- ===== SECCIÓN 1: Creación y Asistencia (Fondo Primario) ===== -->
    <section
        class="relative bg-gradient-to-br from-primary via-[#6a0016] to-[#2a0008] pt-24 md:pt-32 pb-12"
        id="nuestro-trabajo"
    >
        <div
            class="absolute inset-0 opacity-[0.03] bg-[url('data:image/svg+xml;base64,')] pointer-events-none"
        >
        </div>

        <div
            class="container mx-auto px-6 lg:px-12 max-w-[1600px] relative z-10"
        >
            <div
                class="mb-14 flex flex-col items-center md:items-start text-center md:text-left nt-title"
            >
                <h2
                    class="font-serif text-3xl md:text-5xl font-black text-white mb-5 tracking-tight"
                >
                    Capacidades CCD
                </h2>
                <div class="w-24 h-[5px] bg-secondary"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                {
                    row1.map((job) => (
                        <div class="grid-card group bg-white shadow-xl overflow-hidden transition-all duration-300 hover:-translate-y-2 flex flex-col h-full">
                            <div class="relative h-[340px] overflow-hidden bg-gray-100 shrink-0">
                                <img loading="lazy"
                                    src={
                                        job.image ||
                                        "https://res.cloudinary.com/ccdcloudy/image/upload/f_auto,q_auto/v1772646621/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_7_kr73ms.jpg"
                                    }
                                    alt={job.title}
                                    class="w-full h-full object-cover transition-transform duration-[3000ms] group-hover:scale-[1.08]"
                                />
                                <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />
                            </div>
                            <div class="p-10 flex flex-col flex-grow">
                                <h3 class="font-sans text-2xl font-bold text-gray-900 mb-4 group-hover:text-primary transition-colors leading-tight">
                                    {job.title}
                                </h3>
                                <p class="font-sans text-gray-600 leading-relaxed text-lg">
                                    {job.bullet}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- ===== SECCIÓN 2: Optimización de Procesos (Fondo Gris Claro) ===== -->
    <section class="bg-[#F1F5F9] py-16 md:py-20 border-y border-gray-200">
        <div class="container mx-auto px-6 lg:px-12 max-w-[1600px]">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                {
                    row2.map((job) => (
                        <div class="grid-card group bg-white shadow-xl overflow-hidden transition-all duration-300 hover:-translate-y-2 flex flex-col h-full">
                            <div class="relative h-[340px] overflow-hidden bg-gray-100 shrink-0">
                                <img loading="lazy"
                                    src={
                                        job.image ||
                                        "https://res.cloudinary.com/ccdcloudy/image/upload/f_auto,q_auto/v1770857524/Web%20CCD/Corporate%20Flat%20Illustration/planes_de_desarrollo2_tb0bj3.jpg"
                                    }
                                    alt={job.title}
                                    class="w-full h-full object-cover transition-transform duration-[3000ms] group-hover:scale-[1.08]"
                                />
                                <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />
                            </div>
                            <div class="p-10 flex flex-col flex-grow">
                                <h3 class="font-sans text-2xl font-bold text-gray-900 mb-4 group-hover:text-primary transition-colors leading-tight">
                                    {job.title}
                                </h3>
                                <p class="font-sans text-gray-600 leading-relaxed text-lg">
                                    {job.bullet}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- ===== SECCIÓN 3: Gobernanza y Sostenibilidad (Fondo Slate 200) ===== -->
    <section class="bg-[#e2e8f0] py-20 md:py-24 border-b border-gray-300">
        <div class="container mx-auto px-6 lg:px-12 max-w-[1600px]">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {
                    row3.map((job) => (
                        <div class="grid-card group bg-white shadow-xl overflow-hidden transition-all duration-300 hover:-translate-y-2 flex flex-col h-full">
                            <div class="relative h-[280px] overflow-hidden bg-gray-100 shrink-0">
                                <img loading="lazy"
                                    src={
                                        job.image ||
                                        "https://res.cloudinary.com/ccdcloudy/image/upload/f_auto,q_auto/v1774886325/Web%20CCD/Capacidades%20e%20Industrias/Fondos%20Sociales/image_j2vjuk.webp"
                                    }
                                    alt={job.title}
                                    class="w-full h-full object-cover transition-transform duration-[3000ms] group-hover:scale-[1.08]"
                                />
                                <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />
                            </div>
                            <div class="p-8 flex flex-col flex-grow">
                                <h3 class="font-sans text-xl font-bold text-gray-900 mb-3 group-hover:text-primary transition-colors leading-tight">
                                    {job.title}
                                </h3>
                                <p class="font-sans text-gray-600 leading-relaxed text-base">
                                    {job.bullet}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>
</CapabilityLayout>

<style>
    .nt-title {
        animation: fadeSlideUp 0.7s ease-out both;
    }
    .grid-card {
        animation: fadeSlideUp 0.6s ease-out both;
    }

    @keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(25px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
