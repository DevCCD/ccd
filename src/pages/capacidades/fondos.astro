---
import CapabilityLayout from "../../components/capacidades/CapabilityLayout.astro";
import { teamMembers, industriesData } from "../../data/teamData";

const selectedSpecialists = [
    teamMembers["rudy-laguna"],
    teamMembers["elmer-huaman"],
    teamMembers["alvaro-gordillo"],
    teamMembers["alex-carbajal"],
    teamMembers["jorge-ruiz"],
];

const selectedIndustries = [
    industriesData["mineria"],
    industriesData["agropecuario"],
];

// Bento Grid Items for Generación de Valor Cliente
const valueGenerationItems = [
    {
        text: "Aceleran el proceso de desarrollo local y comunal.",
        image: "/capacidades/fondos/sostenible.png",
        imageAlt: "Gobernanza",
        size: "small" as const,
    },
    {
        text: "Cofinancian y potencian la intervención pública y privada en favor del desarrollo de la población.",
        image: "/capacidades/fondos/fondos-v2.png",
        imageAlt: "Cofinanciamiento",
        size: "medium" as const,
    },
];

// Bento Grid Items for Nuestro Trabajo
const ourWorkItems = [
    {
        text: "Evaluar, diseñar y brindar asistencia técnica en la constitución y operatividad de fondos de desarrollo.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772645488/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_4_u9bmzk.jpg",
        imageAlt: "Gobernanza",
        size: "small" as const,
    },
    {
        text: "Mejorar gobernanza de los fondos sociales.",
        image: "https://images.unsplash.com/photo-1553729459-efe14ef6055d?w=800&h=600&fit=crop",
        imageAlt: "Estructuración",
        size: "medium" as const,
    },
    {
        text: "Diseñar, fortalecer capacidades y asistencia técnica para mejorar y optimizar procesos, MAPROS, comités, protocolos y manuales para mejorar la inversión social.",
        image: "/capacidades/fondos/monitoreo.jpg",
        imageAlt: "Monitoreo",
        size: "medium" as const,
    },
    {
        text: "Diseñar e implementar estrategias para potenciar procesos participativos de los beneficiarios en los fondos sociales.",
        image: "https://images.unsplash.com/photo-1551836022-d5d88e9218df?w=800&h=600&fit=crop",
        imageAlt: "Gobernanza",
        size: "small" as const,
    },
    {
        text: "Estructuramos mecanismos de complementariedad y sostenibilidad de los fondos sociales con otras fuentes de financiamiento para el desarrollo.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772649818/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_16_pv06zc.jpg",
        imageAlt: "Estructuración",
        size: "small" as const,
    },
    {
        text: "La experiencia pública y privada incluye la participación en el diseño, constitución y operatividad de más de cincuenta (50) fondos de desarrollo en comunidades, distritos y regiones del país.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772649710/Web%20CCD/Capacidades%20e%20Industrias/Fondos%20de%20Desarrollo/clima-inversiones-RD_nkgqdp.png",
        imageAlt: "Monitoreo",
        size: "medium" as const,
    },
];

const headerImage =
    "https://res.cloudinary.com/ccdcloudy/image/upload/v1772641183/Web%20CCD/Capacidades%20e%20Industrias/Fondos%20de%20Desarrollo/Fondos_fljzpp.webp";
---

<CapabilityLayout
    title="Fondos de Desarrollo"
    description="Los fondos de desarrollo con una adecuada gobernanza aceleran el progreso local y potencian la inversión pública y privada, creando mecanismos sostenibles de financiamiento."
    headerImage={headerImage}
    valueGenerationItems={valueGenerationItems}
    ourWorkItems={ourWorkItems}
    specialists={selectedSpecialists}
    industries={selectedIndustries}
    nextCapability={{
        title: "Evaluación de Programas y Proyectos",
        link: "/capacidades/evaluacion",
    }}
>
    <!-- Slot para contenido antes de Valor Cliente (o Trabajo) -->
    <div
        slot="before-value"
        class="bg-gradient-to-br from-gray-50 to-white rounded-3xl p-8 md:p-12 border border-gray-200 shadow-sm mb-12"
    >
        <h4
            class="font-serif text-2xl font-bold text-gray-900 mb-8 pb-4 border-b border-gray-200"
        >
            Los fondos de desarrollo locales o comunales contribuyen con la
            gestión social de la empresa:
        </h4>
        <ul
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-5"
        >
            {
                [
                    "Legitimidad",
                    "Proceso participativo",
                    "Generación de confianza con actores",
                    "Mayor calidad y rapidez en las intervenciones con los proyectos sociales",
                    "Mejores beneficios para la población",
                ].map((item) => (
                    <li class="flex items-start group">
                        <span class="w-2 h-2 rounded-full bg-primary mt-2 mr-3 flex-shrink-0 group-hover:scale-150 transition-transform" />
                        <span class="text-gray-700 font-medium text-base group-hover:text-primary transition-colors">
                            {item}
                        </span>
                    </li>
                ))
            }
        </ul>
    </div>
</CapabilityLayout>
