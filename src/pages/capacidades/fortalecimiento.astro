---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import ValueGenerationHero from "../../components/capacidades/ValueGenerationHero.astro";
import BentoGrid from "../../components/capacidades/BentoGrid.astro";
import CapabilitySidebar from "../../components/capacidades/CapabilitySidebar.astro";

// Importamos nuestra "base de datos"
import { teamMembers, industriesData } from "../../data/teamData";

const selectedSpecialists = [
    teamMembers["sergio-villegas"],
    teamMembers["elmer-huaman"],
    teamMembers["rudy-laguna"],
    teamMembers["melissa-sanchez"],
    teamMembers["karla-casas"],
];

const selectedIndustries = [
    industriesData["publico"],
    industriesData["inteligencia"],
    industriesData["infraestructura"],
    industriesData["educacion"],
];

// Bento Grid Items for Generación de Valor Cliente
const valueGenerationItems = [
    {
        text: "Viabilizar componentes político y técnico para el desarrollo.",
        image: "/capacidades/fortalecimiento de capacidades/1.JPG",
        imageAlt: "Viabilidad",
        size: "small" as const,
    },
    {
        text: "Lograr acuerdos para el desarrollo.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772648208/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_12_w6wo7v.jpg",
        imageAlt: "Eficiencia",
        size: "small" as const,
    },
    {
        text: "Generación de confianza.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772647988/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_10_vkzx2l.jpg",
        imageAlt: "Transferencia",
        size: "small" as const,
    },
    {
        text: "Mayor articulación e integración con los actores claves del desarrollo.",
        image: "/capacidades/fortalecimiento de capacidades/4.jpg",
        imageAlt: "Liderazgo",
        size: "small" as const,
    },
    {
        text: "Generación de eficiencias internas y externas.",
        image: "/capacidades/fortalecimiento de capacidades/5.jpg",
        imageAlt: "Inclusión",
        size: "medium" as const,
    },
    {
        text: "Cofinanciamiento público y privado y escalamiento de programas y proyectos sociales para el desarrollo.",
        image: "/capacidades/fortalecimiento de capacidades/IMG_1012.JPG",
        imageAlt: "Transferencia",
        size: "wide" as const,
    },
    {
        text: "Aceleración y aumento de la calidad de la inversión.",
        image: "/capacidades/fortalecimiento de capacidades/000874631W.jpg",
        imageAlt: "Liderazgo",
        size: "small" as const,
    },
    {
        text: "Potenciación de la inversión pública y privada para el desarrollo.",
        image: "/capacidades/fortalecimiento de capacidades/reunion.jpg",
        imageAlt: "Inclusión",
        size: "medium" as const,
    },
];

// Bento Grid Items for Nuestro Trabajo
const ourWorkItems = [
    {
        text: "Administración Financiera del Sector Público:",
        bullets: [
            "Programación Multianual y Gestión de Inversiones: Invierte.pe",
            "Gestión Fiscal de los Recursos Humanos en el Sector Público",
            "Presupuesto Público",
            "Abastecimiento: compras públicas",
            "Tesorería",
            "Endeudamiento Público",
            "Contabilidad",
            "Ingresos y Rentas",

            "Integridad institucional",
        ],
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772648854/Web%20CCD/Capacidades%20e%20Industrias/Desarrollo/admfinanciera_xdzdcb.png",
        imageAlt: "Planes de Competitividad",
        size: "wide" as const,
    },

    {
        text: "Fortalecimiento de capacidades bajo las modalidades: Presencial, Virtual y Semipresencial.",
        image: "/capacidades/fortalecimiento de capacidades/WhatsApp Image 2024-07-11 at 17.38.59 (2).jpeg",
        imageAlt: "Programas",
        size: "small" as const,
    },
    {
        text: "Fortalecimiento de capacidades en desarrollo y proceso de cierre de brechas económicas y sociales a líderes y actores claves.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772648608/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_13_blx3od.jpg",
        imageAlt: "Formación",
        size: "medium" as const,
    },
    {
        text: "Diseño y creación de plataformas y campus fisco y/o virtual para el fortalecimiento de capacidades para planeamiento y gestión del desarrollo.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772649545/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_15_nltxde.jpg",
        imageAlt: "Modernización",
        size: "medium" as const,
    },
    {
        text: "Retroalimentación de mejores experiencias con los mejores gestores de inversión a nivel nacional.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772649392/Web%20CCD/Capacidades%20e%20Industrias/Desarrollo/retroalimetnacion_rm9w5r.png",
        imageAlt: "Programas",
        size: "small" as const,
    },
];

const headerImage =
    "https://res.cloudinary.com/ccdcloudy/image/upload/v1772640780/Web%20CCD/Capacidades%20e%20Industrias/Fortalecimiento/Fortalecimiento_hk8y2r.webp";
---

<Layout title="Fortalecimiento de Capacidades y Capital Humano - CCD">
    <PageHeader
        title="Fortalecimiento de Capacidades y Capital Humano"
        backgroundImage={headerImage}
    />

    <section class="bg-white">
        <div class="container mx-auto px-6 lg:px-12 py-16 md:py-24">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
                <!-- CONTENIDO PRINCIPAL (9 columnas) -->
                <div class="lg:col-span-9 space-y-24">
                    <!-- SECCIÓN 1: GENERACIÓN DE VALOR CLIENTE -->
                    <div class="space-y-12">
                        <ValueGenerationHero
                            title="Generación de Valor Cliente"
                            description="Fortalecemos capacidades institucionales y capital humano para impulsar un desarrollo sostenible, competitivo y resiliente en cada territorio."
                        />

                        <BentoGrid items={valueGenerationItems} />
                    </div>

                    <!-- SECCIÓN 2: NUESTRO TRABAJO -->
                    <div
                        id="nuestro-trabajo"
                        class="scroll-mt-24 space-y-12 pt-12 border-t border-gray-200"
                    >
                        <div class="text-center md:text-left">
                            <h2
                                class="font-serif text-3xl md:text-4xl font-bold text-gray-900 mb-4"
                            >
                                Nuestro{" "}
                                <span class="text-primary italic">
                                    Trabajo
                                </span>
                            </h2>
                        </div>
                        <!-- Ejes de Fortalecimiento -->
                        <div
                            class="bg-gradient-to-br from-gray-50 to-white rounded-3xl p-8 md:p-12 border border-gray-200 shadow-sm"
                        >
                            <h4
                                class="font-serif text-2xl font-bold text-gray-900 mb-8 pb-4 border-b border-gray-200"
                            >
                                Fortalecimiento de capacidades a colaboradores y
                                funcionarios de las instituciones públicas y
                                privadas para el desarrollo nacional, regional,
                                local y comunal:
                            </h4>
                            <ul
                                class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-5"
                            >
                                {
                                    [
                                        "Determinantes de la competitividad, productividad y desarrollo",

                                        "Articulación y complementariedad de los instrumentos de planeamiento y gestión para el desarrollo",
                                        "Inversión pública: Invierte.pe, Programación Multianual de Inversiones y Gestión de Inversiones",
                                        "Planeamiento para el desarrollo",
                                        "Obras por Impuestos",
                                        "Asociaciones Público Privado: APPs",
                                        "Iniciativas Privadas",
                                        "Fondos sociales para el desarrollo",
                                    ].map((item) => (
                                        <li class="flex items-start group">
                                            <span class="w-2 h-2 rounded-full bg-primary mt-2 mr-3 flex-shrink-0 group-hover:scale-150 transition-transform" />
                                            <span class="text-gray-700 font-medium text-base group-hover:text-primary transition-colors">
                                                {item}
                                            </span>
                                        </li>
                                    ))
                                }
                            </ul>
                        </div>

                        <BentoGrid items={ourWorkItems} />

                        <!-- Siguiente Capacidad -->
                        <div class="pt-12">
                            <a
                                href="/capacidades/fondos"
                                class="group flex items-center justify-between p-8 rounded-2xl bg-gray-50 border border-gray-100 hover:border-primary/30 transition-all"
                            >
                                <div>
                                    <span
                                        class="text-sm font-bold text-primary uppercase tracking-widest"
                                        >Siguiente Capacidad</span
                                    >
                                    <h4
                                        class="text-2xl font-serif font-bold text-gray-900 mt-2"
                                    >
                                        Fondos de Desarrollo
                                    </h4>
                                </div>
                                <div
                                    class="w-12 h-12 rounded-full bg-white border border-gray-200 flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-6 w-6"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- COLUMNA DERECHA: SIDEBAR (3/12) -->
                <CapabilitySidebar
                    specialists={selectedSpecialists}
                    industries={selectedIndustries}
                />
            </div>
        </div>
    </section>
</Layout>
