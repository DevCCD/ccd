---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import ValueGenerationHero from "../../components/capacidades/ValueGenerationHero.astro";
import BentoGrid from "../../components/capacidades/BentoGrid.astro";
import CapabilitySidebar from "../../components/capacidades/CapabilitySidebar.astro";

// Importamos nuestra "base de datos"
import { teamMembers, industriesData } from "../../data/teamData";

const selectedSpecialists = [
    teamMembers["viviana-sanchez"],
    teamMembers["rudy-laguna"],
    teamMembers["sergio-villegas"],
    teamMembers["elmer-huaman"],
    teamMembers["jorge-ruiz"],
    teamMembers["fernando-jauregui"],
];

const selectedIndustries = [
    industriesData["infraestructura"],
    industriesData["financiero"],
    industriesData["mineria"],
    industriesData["hidrocarburos"],
];

// Bento Grid Items for Generación de Valor Cliente
const valueGenerationItems = [
    {
        text: "Desarrollo y prosperidad para todos.",
        image: "/capacidades/inversiones y proyectos/anta.png",
        imageAlt: "Estudios de Inversión",
        size: "wide" as const,
    },
];

// Bento Grid Items for Nuestro Trabajo
const ourWorkItems = [
    {
        text: "Fortalecer capacidades y asistencia técnica para elaborar Programas Multianuales de Inversiones (PMI).",
        image: "/capacidades/inversiones y proyectos/inversiones.jpg",
        imageAlt: "Estudios",
        size: "medium" as const,
    },
    {
        text: "Elaborar programas de inversiones para impulsar el desarrollo y la competitividad.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1770829211/Web%20CCD/Corporate%20Flat%20Illustration/plan_de_desarollo_pcbbxp.png",
        imageAlt: "Gestión",
        size: "small" as const,
    },
    {
        text: "Fortalecer capacidades y asistencia técnica integral a equipos de profesionales y colaboradores de organizaciones públicas y privadas para mejorar velocidad y calidad en la ejecución de inversión.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772651953/Web%20CCD/Capacidades%20e%20Industrias/Inversiones/ejec_zfghpf.png",
        imageAlt: "Alianzas",
        size: "wide" as const,
    },
    {
        text: "Diseñar e implementar proyectos innovadores de inversión en todas las dimensiones del desarrollo y determinantes de la competitividad.",
        image: "/capacidades/inversiones y proyectos/desarrollo 1.jpg",
        imageAlt: "Gestión",
        size: "medium" as const,
    },
    {
        text: "Asesorar y asistencia técnica en modalidades de inversión Obras por Impuestos, Asociaciones Publico Privadas e Iniciativas Privadas.",
        image: "https://res.cloudinary.com/ccdcloudy/image/upload/v1772648154/Web%20CCD/Corporate%20Flat%20Illustration/Image_fx_11_l8petx.jpg",
        imageAlt: "Alianzas",
        size: "small" as const,
    },
];

const headerImage =
    "https://res.cloudinary.com/ccdcloudy/image/upload/v1772644229/Web%20CCD/Capacidades%20e%20Industrias/Inversiones/inversiones2_gxdoll.jpg";
---

<Layout title="Inversiones y Proyectos de Desarrollo - CCD">
    <PageHeader
        title="Inversiones y Proyectos de Desarrollo"
        backgroundImage={headerImage}
    />

    <section class="bg-white">
        <div class="container mx-auto px-6 lg:px-12 py-16 md:py-24">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
                <!-- CONTENIDO PRINCIPAL (9 columnas) -->
                <div class="lg:col-span-9 space-y-24">
                    <!-- SECCIÓN 1: GENERACIÓN DE VALOR CLIENTE -->
                    <div class="space-y-12">
                        <ValueGenerationHero
                            title="Generación de Valor Cliente"
                            description="Inversiones y proyectos permiten reducir y cerrar brechas, desarrollo y mejoran calidad de vida de la población."
                        />

                        <BentoGrid items={valueGenerationItems} />
                    </div>

                    <!-- SECCIÓN 2: NUESTRO TRABAJO -->
                    <div
                        id="nuestro-trabajo"
                        class="scroll-mt-24 space-y-12 pt-12 border-t border-gray-200"
                    >
                        <div class="text-center md:text-left">
                            <h2
                                class="font-serif text-3xl md:text-4xl font-bold text-gray-900 mb-4"
                            >
                                Nuestro{" "}
                                <span class="text-primary italic">
                                    Trabajo
                                </span>
                            </h2>
                        </div>

                        <div
                            class="bg-gradient-to-br from-gray-50 to-white rounded-3xl p-8 md:p-12 border border-gray-200 shadow-sm"
                        >
                            <h4
                                class="font-serif text-2xl font-bold text-gray-900 mb-8 pb-4 border-b border-gray-200"
                            >
                                Elaborar estudios para proyectos de inversión
                            </h4>
                            <ul
                                class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-x-8 gap-y-5"
                            >
                                {
                                    [
                                        "Tipo: preinversión, expedientes técnicos, prefactibilidad y factibilidad",
                                        "Rubro: dimensiones del desarrollo y determinantes de la competitividad",
                                        "Tamaño: mega, grande, mediano y pequeño",
                                        "Sectores: educación, salud, saneamiento, productivos, seguridad penitenciaria, entre otros",
                                    ].map((item) => (
                                        <li class="flex items-start group">
                                            <span class="w-2 h-2 rounded-full bg-primary mt-2 mr-3 flex-shrink-0 group-hover:scale-150 transition-transform" />
                                            <span class="text-gray-700 font-medium text-base group-hover:text-primary transition-colors">
                                                {item}
                                            </span>
                                        </li>
                                    ))
                                }
                            </ul>
                        </div>

                        <BentoGrid items={ourWorkItems} />

                        <!-- Tipos de Inversión -->

                        <!-- Siguiente Capacidad -->
                        <div class="pt-12">
                            <a
                                href="/capacidades/competitividad"
                                class="group flex items-center justify-between p-8 rounded-2xl bg-gray-50 border border-gray-100 hover:border-primary/30 transition-all"
                            >
                                <div>
                                    <span
                                        class="text-sm font-bold text-primary uppercase tracking-widest"
                                        >Siguiente Capacidad</span
                                    >
                                    <h4
                                        class="text-2xl font-serif font-bold text-gray-900 mt-2"
                                    >
                                        Competitividad
                                    </h4>
                                </div>
                                <div
                                    class="w-12 h-12 rounded-full bg-white border border-gray-200 flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-6 w-6"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- COLUMNA DERECHA: SIDEBAR (3/12) -->
                <CapabilitySidebar
                    specialists={selectedSpecialists}
                    industries={selectedIndustries}
                />
            </div>
        </div>
    </section>
</Layout>
