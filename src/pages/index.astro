---
import Layout from "../layouts/Layout.astro";
import TeamCard from "../components/TeamCard.astro";

// Importamos los datos centralizados
import { teamMembers } from "../data/teamData";

// Directores principales
const directores = [
    teamMembers["rudy-laguna"],
    teamMembers["viviana-sanchez"],
    teamMembers["alvaro-gordillo"],
];
---

<Layout
    title="CCD - Centro para la Competitividad y el Desarrollo"
    description="Promovemos el desarrollo territorial sostenible a través de soluciones integrales en competitividad, inversión y evaluación de proyectos."
>
    <section class="bg-white pt-16 pb-16 px-6 sm:px-8 xl:px-0">
        <div class="max-w-screen-xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                <!-- Left Column: Title and 2 Cards -->
                <div class="lg:col-span-8 flex flex-col gap-6">
                    <!-- Title Block -->
                    <div
                        class="bg-white pr-4 lg:pr-12 pb-4 lg:pb-12 flex flex-col justify-center min-h-[30vh]"
                    >
                        <h1
                            id="hero-title"
                            class="font-serif text-5xl sm:text-6xl md:text-7xl lg:text-[4.5rem] font-bold text-primary leading-[1.05] tracking-tight mb-8"
                        >
                            El Futuro de <br class="hidden md:block" /> las Comunidades
                        </h1>
                        <div
                            class="flex flex-col sm:flex-row sm:items-center gap-6 sm:gap-12"
                        >
                            <p
                                id="hero-subtitle"
                                class="font-sans text-xl md:text-2xl text-gray-700 max-w-xl"
                            >
                                Cada vez son más las comunidades que priorizan
                                la conectividad económica, física y vital.
                            </p>
                            <a
                                id="hero-button"
                                href="/contacto"
                                class="shrink-0 flex items-center justify-center w-16 h-16 rounded-full border border-gray-300 hover:border-primary text-primary hover:bg-primary hover:text-white transition-all duration-300 group"
                            >
                                <svg
                                    class="w-8 h-8 transform group-hover:translate-x-1 transition-transform"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="1.5"
                                        d="M14 5l7 7m0 0l-7 7m7-7H3"
                                    ></path></svg
                                >
                            </a>
                        </div>
                    </div>

                    <!-- 2 Cards Row -->
                    <div
                        class="grid grid-cols-1 sm:grid-cols-2 gap-6 flex-grow"
                    >
                        <!-- Card 1: Países -->
                        <a
                            href="/paises"
                            class="group relative overflow-hidden flex flex-col justify-end bg-gray-900 min-h-[350px] md:min-h-[400px]"
                        >
                            <img
                                src="https://res.cloudinary.com/ccdcloudy/image/upload/v1773305978/Web%20CCD/paises/comercio-exterior_indice-de-conectividad-global-050424-010226_gvj4pp.jpg"
                                alt="Países"
                                class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                            />
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-gray-900/90 via-gray-900/20 to-transparent"
                            >
                            </div>
                            <div class="relative z-10 p-6 md:p-8">
                                <p
                                    class="text-white/80 text-sm font-bold tracking-widest uppercase mb-3"
                                >
                                    Cobertura Global
                                </p>
                                <h3
                                    class="text-white text-3xl font-serif font-bold group-hover:text-gray-200 transition-colors flex items-center"
                                >
                                    Países
                                    <svg
                                        class="w-5 h-5 ml-2 opacity-0 group-hover:opacity-100 transform -translate-x-4 group-hover:translate-x-0 transition-all duration-300"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2.5"
                                            d="M9 5l7 7-7 7"></path></svg
                                    >
                                </h3>
                            </div>
                        </a>

                        <!-- Card 2: Competitividad -->
                        <a
                            href="/capacidades/competitividad"
                            class="group relative overflow-hidden flex flex-col justify-end bg-gray-900 min-h-[350px] md:min-h-[400px]"
                        >
                            <img
                                src="https://res.cloudinary.com/ccdcloudy/image/upload/v1772640888/Web%20CCD/Capacidades%20e%20Industrias/Competitividad/Competitividad_inpcde.webp"
                                alt="Competitividad"
                                class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                            />
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-gray-900/90 via-gray-900/20 to-transparent"
                            >
                            </div>
                            <div class="relative z-10 p-6 md:p-8">
                                <p
                                    class="text-white/80 text-sm font-bold tracking-widest uppercase mb-3"
                                >
                                    Nuestras Capacidades
                                </p>
                                <h3
                                    class="text-white text-3xl font-serif font-bold group-hover:text-gray-200 transition-colors flex items-center"
                                >
                                    Competitividad
                                    <svg
                                        class="w-5 h-5 ml-2 opacity-0 group-hover:opacity-100 transform -translate-x-4 group-hover:translate-x-0 transition-all duration-300"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2.5"
                                            d="M9 5l7 7-7 7"></path></svg
                                    >
                                </h3>
                            </div>
                        </a>
                    </div>
                </div>

                <!-- Right Column: 2 Stacked Cards -->
                <div id="hero-image" class="lg:col-span-4 flex flex-col gap-6">
                    <!-- Tall Featured Card 1: Minería -->
                    <a
                        href="/industrias/mineria"
                        class="group relative overflow-hidden flex flex-col justify-end bg-gray-900 h-full min-h-[300px]"
                    >
                        <img
                            src="https://res.cloudinary.com/ccdcloudy/image/upload/v1773340518/Web%20CCD/Industrias/mineria_ymbax9.jpg"
                            alt="Minería"
                            class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 bg-white"
                        />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/40 to-black/10"
                        >
                        </div>
                        <div class="relative z-10 p-6 md:p-8">
                            <p
                                class="text-white/80 text-sm font-bold tracking-widest uppercase mb-3"
                            >
                                Industrias Principales
                            </p>
                            <h3
                                class="text-white text-3xl md:text-4xl font-serif font-bold leading-tight group-hover:text-gray-200 transition-colors"
                            >
                                Minería
                            </h3>
                        </div>
                    </a>

                    <!-- Tall Featured Card 2: Enfoque de Trabajo -->
                    <a
                        href="/nosotros/enfoque"
                        class="group relative overflow-hidden flex flex-col justify-end bg-gray-900 h-full min-h-[300px]"
                    >
                        <img
                            src="/capacidades/capacidades.png"
                            alt="Enfoque de Trabajo"
                            class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 bg-white"
                        />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/40 to-black/10"
                        >
                        </div>
                        <div class="relative z-10 p-6 md:p-8">
                            <p
                                class="text-white/80 text-sm font-bold tracking-widest uppercase mb-3"
                            >
                                Metodología
                            </p>
                            <h3
                                class="text-white text-3xl md:text-4xl font-serif font-bold leading-tight group-hover:text-gray-200 transition-colors"
                            >
                                Enfoque de Trabajo
                            </h3>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- SECCIÓN: INTRO/VALUE PROP -->
    <section
        class="py-24 bg-gradient-to-r from-primary-dark via-primary to-primary-dark text-white text-center"
    >
        <div class="container mx-auto px-6 max-w-4xl">
            <p
                class="font-serif text-xl md:text-xl text-white font-light gsap-fade-up leading-[1.8] md:leading-[1.9]"
            >
                Visión
            </p>
            <br />
            <p
                class="font-serif text-3xl md:text-4xl text-white leading-relaxed font-light gsap-fade-up leading-[1.8] md:leading-[1.3]"
            >
                "Promover el desarrollo y la prosperidad con oportunidades y
                alta calidad de vida de la población nacional, regional,
                provincial, distrital y comunal."
            </p>
        </div>
    </section>

    <!-- SECCIÓN: CAPACIDADES - FEATURE BLOCK -->
    <section class="bg-gray-50 py-20 lg:py-28">
        <div class="container mx-auto px-6 md:px-12">
            <div
                class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20"
            >
                <!-- Imagen -->
                <div class="w-full lg:w-1/2 order-2 lg:order-1">
                    <div
                        class="relative overflow-hidden rounded-sm shadow-lg aspect-video"
                    >
                        <img
                            src="/capacidades/capacidades.png"
                            alt="Nuestras Capacidades"
                            class="w-full h-full object-cover transform hover:scale-105 transition-transform duration-700"
                        />
                    </div>
                </div>

                <!-- Contenido -->
                <div class="w-full lg:w-1/2 order-1 lg:order-2 gsap-slide-left">
                    <h2
                        class="font-serif text-4xl sm:text-5xl font-bold text-gray-900 mb-6 leading-tight"
                    >
                        Nuestras Capacidades
                    </h2>
                    <div class="w-20 h-1 bg-primary mb-8"></div>
                    <p class="text-gray-600 text-lg leading-relaxed mb-8">
                        Ofrecemos soluciones integrales en competitividad,
                        desarrollo territorial, inversión y evaluación de
                        proyectos. Nuestro enfoque multidisciplinario transforma
                        comunidades y genera impacto sostenible a largo plazo.
                    </p>
                    <a
                        href="/capacidades"
                        class="group inline-flex items-center text-primary font-bold text-lg hover:text-primary-dark transition-colors"
                    >
                        <span>Ver Capacidades</span>
                        <svg
                            class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
                        >
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- SECCIÓN: INDUSTRIAS - FEATURE BLOCK ALTERNADO -->
    <section class="bg-white py-20 lg:py-28">
        <div class="container mx-auto px-6 md:px-12">
            <div
                class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20"
            >
                <!-- Contenido (Izquierda en Desktop) -->
                <div class="w-full lg:w-1/2 order-1 gsap-slide-right">
                    <h2
                        class="font-serif text-4xl sm:text-5xl font-bold text-gray-900 mb-6 leading-tight"
                    >
                        Nuestras Industrias
                    </h2>
                    <div class="w-20 h-1 bg-primary mb-8"></div>
                    <p class="text-gray-600 text-lg leading-relaxed mb-8">
                        Aportamos experiencia estratégica en múltiples sectores
                        económicos, potenciando el crecimiento, la innovación y
                        la competitividad de industrias clave dentro del
                        territorio.
                    </p>
                    <a
                        href="/industrias"
                        class="group inline-flex items-center text-primary font-bold text-lg hover:text-primary-dark transition-colors"
                    >
                        <span>Ver Industrias</span>
                        <svg
                            class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
                        >
                    </a>
                </div>

                <!-- Imagen (Derecha en Desktop) -->
                <div class="w-full lg:w-1/2 order-2">
                    <div
                        class="relative overflow-hidden rounded-sm shadow-lg aspect-video"
                    >
                        <img
                            src="/industrias/industrias.png"
                            alt="Nuestras Industrias"
                            class="w-full h-full object-cover transform hover:scale-105 transition-transform duration-700"
                        />
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECCIÓN: EQUIPO PRINCIPAL -->
    <section
        class="bg-gradient-to-b from-secondary-light/20 to-secondary py-16 md:py-24"
    >
        <div class="container mx-auto px-6">
            <h2
                class="font-serif text-4xl md:text-5xl font-bold text-black text-center mb-4"
            >
                Nuestro Equipo
            </h2>
            <p
                class="text-center text-gray-600 text-lg max-w-2xl mx-auto mb-16"
            >
                Líderes y especialistas con experiencia en desarrollo
                territorial, inversión y competitividad regional.
            </p>

            <!-- Grid de Equipo: 3 columnas centradas -->
            <div
                class="grid grid-cols-1 md:grid-cols-3 gap-12 max-w-5xl mx-auto gsap-team-grid"
            >
                {
                    directores.map((member) => (
                        <div class="gsap-team-card">
                            <TeamCard
                                name={member.name}
                                role={member.role}
                                image={member.image}
                                link={`/nosotros/equipo/${member.slug}`}
                            />
                        </div>
                    ))
                }
            </div>

            <!-- Enlace a equipo completo -->
            <div class="text-center mt-16">
                <a
                    href="/nosotros/equipo"
                    class="inline-block bg-primary border-2 border-primary text-white font-bold py-3 px-8 rounded-lg hover:bg-primary-dark hover:text-white transition-all duration-300"
                >
                    Ver Equipo Completo
                </a>
            </div>
        </div>
    </section>
</Layout>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    // Registramos el plugin para que funcione con el scroll
    gsap.registerPlugin(ScrollTrigger);

    // ==========================================
    // 1. ANIMACIÓN DEL HERO (Aparece al cargar)
    // ==========================================
    const heroTl = gsap.timeline();
    heroTl
        .from("#hero-title", {
            opacity: 0,
            y: 40,
            duration: 1,
            ease: "power3.out",
        })
        .from(
            "#hero-subtitle",
            { opacity: 0, y: 40, duration: 1, ease: "power3.out" },
            "-=0.7",
        )
        .from(
            "#hero-button",
            { opacity: 0, y: 40, duration: 1, ease: "power3.out" },
            "-=0.8",
        )
        .from(
            "#hero-image",
            { opacity: 0, x: 50, duration: 1.2, ease: "power3.out" },
            "-=1",
        );

    // ==========================================
    // 2. ANIMACIONES AL HACER SCROLL
    // ==========================================

    // A. Elementos que suben suavemente (Textos, Títulos)
    gsap.utils.toArray(".gsap-fade-up").forEach((elem: any) => {
        gsap.from(elem, {
            scrollTrigger: {
                trigger: elem,
                start: "top 85%", // La animación empieza cuando el elemento toca el 85% de la pantalla
                toggleActions: "play none none none",
            },
            y: 50,
            opacity: 0,
            duration: 1,
            ease: "power3.out",
        });
    });

    // B. Elementos que entran desde la Izquierda (Imágenes o Textos)
    gsap.utils.toArray(".gsap-slide-left").forEach((elem: any) => {
        gsap.from(elem, {
            scrollTrigger: { trigger: elem, start: "top 85%" },
            x: -60,
            opacity: 0,
            duration: 1.2,
            ease: "power3.out",
        });
    });

    // C. Elementos que entran desde la Derecha (Imágenes o Textos)
    gsap.utils.toArray(".gsap-slide-right").forEach((elem: any) => {
        gsap.from(elem, {
            scrollTrigger: { trigger: elem, start: "top 85%" },
            x: 60,
            opacity: 0,
            duration: 1.2,
            ease: "power3.out",
        });
    });

    // D. Efecto Cascada (Stagger) para las tarjetas del Equipo
    gsap.from(".gsap-team-card", {
        scrollTrigger: {
            trigger: ".gsap-team-grid", // Contenedor padre
            start: "top 80%",
        },
        y: 50,
        opacity: 0,
        duration: 0.8,
        stagger: 0.2, // Cada tarjeta aparece 0.2s después de la anterior
        ease: "power3.out",
    });
</script>
