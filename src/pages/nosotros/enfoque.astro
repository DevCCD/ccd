---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<Layout title="Enfoque de Trabajo - CCD">
    <!-- 1. ENCABEZADO REUTILIZABLE -->
    <PageHeader
        title="Enfoque de Trabajo"
        description="Promover la competitividad y desarrollo con principios de libertad, persuasión, análisis integral y procesos metodológicos."
    />

    <!-- SECCIÓN 1: DIAGNÓSTICO -> METAS -->
    <section class="bg-white py-12 md:py-24">
        <div class="container mx-auto px-4">
            <div class="max-w-3xl mx-auto">
                <img
                    src="/enfoque-trabajo.svg"
                    alt="Gráfico circular de enfoque: Diagnóstico, Intervenciones, Visión, etc."
                    class="w-full h-auto object-contain mx-auto animate-fade-up"
                />
            </div>
        </div>
    </section>

    <!-- SECCIÓN 2: FLUJO DE TRABAJO -->
    <section
        class="bg-gradient-to-b from-gray-200 to-white py-8 md:py-12 border-t border-secondary-light/20"
    >
        <div class="container mx-auto px-4">
            <!-- Título de la sección -->
            <h2
                class="text-center font-serif text-4xl md:text-5xl font-bold text-primary mb-16 md:mb-20"
            >
                Flujo de Trabajo
            </h2>

            <!-- GRÁFICO 2: ENGRANAJES / FLUJO -->
            <div class="max-w-6xl mx-auto">
                <img
                    src="/flujo-trabajo.svg"
                    alt="Diagrama de flujo de trabajo: Planificación, Gestión, Fortalecimiento..."
                    class="w-full h-auto object-contain mx-auto animate-fade-up delay-200"
                />
            </div>
        </div>
    </section>
</Layout>

<style>
    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-fade-up {
        animation: fadeUp 0.8s ease-out forwards;
        opacity: 0;
    }
    .delay-200 {
        animation-delay: 0.2s;
    }
</style>
