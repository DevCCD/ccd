---
import Layout from "../../../layouts/Layout.astro";
import SidebarCard from "../../../components/SidebarCard.astro";
import { teamMembers } from "../../../data/teamData";
import { industriesContent } from "../../../data/industriesContent";
import { capacidadesContent } from "../../../data/capacidadesContent";

// En modo SSR, obtener el miembro dinámicamente desde el slug
const { slug } = Astro.params;
const member = teamMembers[slug];

if (!member) {
  return Astro.redirect("/404");
}
---

<Layout title={`${member.name} - CCD`}>
  <!-- ============================================ -->
  <!-- 1. HEADER HERO (REDIMENSIONADO)              -->
  <!-- ============================================ -->
  <!-- Fondo: Gradiente suave de blanco a celeste CCD -->
  <header
    class="bg-gradient-to-b from-white via-[#EAF4FF] to-[#EAF4FF] pt-10 pb-0 relative overflow-hidden"
  >
    <div class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- COLUMNA TEXTO (Ocupa 7 de 12 columnas for ser más ancho) -->
      <div class="lg:col-span-7 py-12 lg:py-16 self-center">
        <!-- Nombre: Grande y Bold -->
        <h1
          class="font-serif text-5xl md:text-6xl font-black text-gray-900 mb-4 leading-tight"
        >
          {member.name}
        </h1>

        <!-- Cargo: Rojo, Serif y Tamaño mediano (Como en el diseño) -->
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-serif text-2xl md:text-3xl text-primary font-bold">
            {member.role}
          </h2>
        </div>

        <!-- Descripción: Texto grande y con MUCHO interlineado (leading-loose) -->
        <p
          class="font-sans text-lg md:text-xl text-gray-800 leading-[1.8] md:leading-[1.8] font-normal"
        >
          {member.intro}
        </p>

        {
          member.linkedin && (
            <div class="mt-8">
              <a
                href={member.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-400 hover:text-[#0A66C2] transition-colors duration-300 inline-block"
                title={`LinkedIn de ${member.name}`}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="32"
                  height="32"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                </svg>
              </a>
            </div>
          )
        }
      </div>

      <!-- COLUMNA IMAGEN (Ocupa 5 de 12 columnas) -->
      <div
        class="lg:col-span-5 flex justify-center lg:justify-end relative z-10 self-end"
      >
        <!-- 
                    Imagen Grande:
                    - max-h-[650px]: Permite que la imagen sea alta.
                    - object-bottom: Se alinea a la base.
                    - drop-shadow-2xl: Sombra suave para separarla del fondo.
                -->
        <img loading="lazy"
          src={member.photos.detail}
          alt={member.name}
          class="w-full h-auto max-h-[500px] lg:max-h-[600px] object-contain object-bottom drop-shadow-2xl"
        />
      </div>
    </div>
  </header>

  <!-- ============================================ -->
  <!-- 2. CONTENIDO PRINCIPAL                       -->
  <!-- ============================================ -->
  <section class="bg-white py-16 md:py-24">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
        <!-- COLUMNA IZQUIERDA: DETALLES (8/12) -->
        <div class="lg:col-span-8 space-y-16">
          <!-- Acerca de -->
          <div class="prose prose-lg text-gray-700 max-w-none">
            <h3 class="font-serif text-3xl font-bold text-primary mb-6">
              Acerca de {member.name.split(" ")[0]}
            </h3>
            <p
              class="font-sans text-lg md:text-xl text-gray-800 leading-[1.8] md:leading-[1.8] font-normal"
            >
              {member.about}
            </p>
          </div>

          <!-- Experiencia -->
          <div>
            <h3 class="font-serif text-3xl font-bold text-primary mb-6">
              Experiencia
            </h3>
            <div class="space-y-6">
              {
                member.experience.map((paragraph) => (
                  <div class="flex items-start">
                    <p class="font-sans text-lg md:text-xl text-gray-800 leading-[1.8] md:leading-[1.8] font-normal">
                      {paragraph}
                    </p>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- SECCIÓN EDUCACIÓN MEJORADA -->
          <div>
            <h3 class="font-serif text-3xl font-bold text-primary mb-6">
              Educación
            </h3>
            <div class="grid gap-6">
              {
                member.education.map((item) => (
                  <div class="group bg-white p-6 rounded-xl border-l-4 border-primary shadow-sm hover:shadow-lg transition-all duration-300 flex flex-col sm:flex-row items-center justify-between gap-6">
                    {/* --- TEXTO --- */}
                    <div class="flex-1 w-full sm:w-auto text-left">
                      {/* MEJORA 1: Título un poco más grande y oscuro para jerarquía */}
                      <h4 class="font-bold text-gray-900 text-xl md:text-2xl leading-tight mb-2 group-hover:text-primary transition-colors">
                        {item.degree}
                      </h4>

                      <div class="text-gray-500 font-medium text-base md:text-lg">
                        {Array.isArray(item.institution) ? (
                          item.institution.map((instName) => (
                            <div class="block mb-1">{instName}</div>
                          ))
                        ) : (
                          <span>{item.institution}</span>
                        )}
                      </div>
                    </div>

                    {/* --- LOGOS --- */}
                    {item.logos && item.logos.length > 0 && (
                      <div class="flex flex-row items-center justify-center gap-6 mt-4 sm:mt-0 flex-shrink-0">
                        {item.logos.map((logoUrl) => (
                          <img loading="lazy"
                            src={logoUrl}
                            alt="Logo Institución"
                            class="h-16 md:h-18 w-auto object-contain mix-blend-multiply filter grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 ease-in-out"
                          />
                        ))}
                      </div>
                    )}
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <!-- COLUMNA DERECHA: SIDEBAR (4/12) -->
        <aside class="lg:col-span-4 space-y-12">
          <!-- Capacidades -->
          <div>
            <h3
              class="font-serif text-2xl font-bold text-primary mb-6 pb-2 border-b border-gray-200"
            >
              Capacidades
            </h3>
            <div class="space-y-4">
              {
                member.highlightedCapabilities.map((capId) => {
                  const cap = capacidadesContent[capId];
                  if (!cap) return null;
                  return (
                    <SidebarCard
                      title={cap.title}
                      image={cap.headerImage}
                      link={`/capacidades/${capId}`}
                    />
                  );
                })
              }
            </div>
          </div>

          <!-- Industrias -->
          <div>
            <h3
              class="font-serif text-2xl font-bold text-primary mb-6 pb-2 border-b border-gray-200"
            >
              Industrias
            </h3>
            <div class="space-y-4">
              {
                member.highlightedIndustries.map((indId) => {
                  const ind = industriesContent[indId];
                  if (!ind) return null;
                  return (
                    <SidebarCard
                      title={ind.title}
                      image={ind.introImage}
                      link={`/industrias/${indId}`}
                    />
                  );
                })
              }
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
