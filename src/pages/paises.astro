                                    { color: "#0070C0", slug: "estudios", ind: "publico" },
                                    { color: "#0070C0", slug: "estudios", ind: "portuarios" },
                                    { color: "#0070C0", slug: "estudios", ind: "financiero" },
                                    { color: "#0070C0", slug: "estudios", ind: "tecnologia" },
                                ]
                            },
                            {
                                cap: "Inversiones",
                                rowBg: "#76933C",
                                cells: [
                                    { color: "#76933C", slug: "inversiones, evaluacion", ind: "agropecuario" },
                                    { color: "#76933C", slug: "inversiones, evaluacion", ind: "agroexportacion" },
                                    { color: "#76933C", slug: "inversiones, evaluacion", ind: "educacion" },
                                    { color: "#76933C", slug: "inversiones, evaluacion", ind: "hidrocarburos" },
                                    { color: "#76933C", slug: "inversiones, evaluacion", ind: "infraestructura" },
                                    { color: "#76933C", slug: "inversiones, evaluacion", ind: "inteligencia" },
                                    { color: "#76933C", slug: "inversiones, evaluacion", ind: "manufactura" },
                                    { color: "#76933C", slug: "inversiones, evaluacion", ind: "mineria" },
                                    { color: "#76933C", slug: "inversiones, evaluacion", ind: "seguridad" },
                                    { color: "#76933C", slug: "inversiones, evaluacion", ind: "publico" },
                                    { color: "#76933C", slug: "inversiones, evaluacion", ind: "portuarios" },
                                    { color: "#76933C", slug: "inversiones, evaluacion", ind: "financiero" },
                                    { color: "#76933C", slug: "inversiones, evaluacion", ind: "tecnologia" },
                                ]
                            },
                            {
                                cap: "Legal",
                                rowBg: "#60497A",
                                cells: [
                                    { color: "#60497A", slug: "legal", ind: "agropecuario" },
                                    { color: "#60497A", slug: "legal", ind: "agroexportacion" },
                                    { color: "#60497A", slug: "legal", ind: "educacion" },
                                    { color: "#60497A", slug: "legal", ind: "hidrocarburos" },
                                    { color: "#60497A", slug: "legal", ind: "infraestructura" },
                                    { color: "#60497A", slug: "legal", ind: "inteligencia" },
                                    { color: "#60497A", slug: "legal", ind: "manufactura" },
                                    { color: "#60497A", slug: "legal", ind: "mineria" },
                                    { color: "#60497A", slug: "legal", ind: "seguridad" },
                                    { color: "#60497A", slug: "legal", ind: "publico" },
                                    { color: "#60497A", slug: "legal", ind: "portuarios" },
                                    { color: "#60497A", slug: "legal", ind: "financiero" },
                                    { color: "#60497A", slug: "legal", ind: "tecnologia" },
                                ]
                            },
                            {
                                cap: "CCD Tech",
                                rowBg: "#31869B",
                                cells: [
                                    { color: "#31869B", slug: "inteligencia_artificial", ind: "agropecuario" },
                                    { color: "#31869B", slug: "inteligencia_artificial", ind: "agroexportacion" },
                                    { color: "#31869B", slug: "inteligencia_artificial", ind: "educacion" },
                                    { color: "#31869B", slug: "inteligencia_artificial", ind: "hidrocarburos" },
                                    { color: "#31869B", slug: "inteligencia_artificial", ind: "infraestructura" },
                                    { color: "#31869B", slug: "inteligencia_artificial", ind: "inteligencia" },
                                    { color: "#31869B", slug: "inteligencia_artificial", ind: "manufactura" },
                                    { color: "#31869B", slug: "inteligencia_artificial", ind: "mineria" },
                                    { color: "#31869B", slug: "inteligencia_artificial", ind: "seguridad" },
                                    { color: "#31869B", slug: "inteligencia_artificial", ind: "publico" },
                                    { color: "#31869B", slug: "inteligencia_artificial", ind: "portuarios" },
                                    { color: "#31869B", slug: "inteligencia_artificial", ind: "financiero" },
                                    { color: "#31869B", slug: "inteligencia_artificial", ind: "tecnologia" },
                                ]
                            },
                        ].map((row, rowIdx) => (
                            <tr class={`animate-row ${rowIdx % 2 === 0 ? "bg-gray-50" : "bg-white"}`} style={`animation-delay: ${rowIdx * 0.05}s;`}>
                                <!-- Etiqueta de capacidad -->
                                <td class="sticky left-0 z-10 py-4 px-3 text-white text-xs font-bold leading-tight shadow-[2px_0_5px_rgba(0,0,0,0.05)]" style={`background-color:${row.rowBg};`}>
                                    {row.cap}
                                </td>
                                <!-- Celdas de experiencia -->
                                {row.cells.map((cell) => (
                                    <td style="height:0px; padding:0;">
                                        <button
                                            class="matrix-cell w-full h-full min-h-[70px] cursor-pointer transition-all duration-300 hover:brightness-110 hover:scale-[1.08] hover:shadow-[0_4px_15px_rgba(0,0,0,0.2)] hover:z-20 relative opacity-90 hover:opacity-100 rounded-none"
