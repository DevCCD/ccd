                                            aria-expanded="false"
                                        >
                                        </button>
                                    </td>
                                ))}
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>

            

            <!-- Leyenda de colores 
            <div class="mt-10 mx-auto" style="max-width:420px;">
                <h3 class="font-serif text-sm font-bold text-gray-700 mb-3">Leyenda de Colores</h3>
                <div style="display:grid; gap:2px;">
                    {[
                        ["#00B050","#00D25F","#00FF00","#66FF66","#C1FFC1"],
                        ["#E26B0A","#F6903C","#FCD5B4","#FDE9D9","#FEF2E8"],
                        ["#366092","#95B3D7","#B8CCE4","#DCE6F1","#EAF0F6"],
                        ["#76933C","#C4D79B","#D8E4BC","#EBF1DE","#F8FAF4"],
                        ["#60497A","#B1A0C7","#CCC0DA","#E4DFEC","#EDEAF2"],
                        ["#31869B","#92CDDC","#B7DEE8","#DAEEF3","#E5F4F7"],
                    ].map((colors) => (
                        <div style="display:flex; gap:2px;">
                            {colors.map((c) => (
                                <div style={`background-color:${c}; height:14px; flex:1; min-width:0; border-radius:2px;`}></div>
                            ))}
                        </div>
                    ))}
                </div>
                <div class="flex justify-between mt-1.5 text-[10px] text-gray-400 font-sans">
                    <span>Mayor experiencia</span>
                    <span>Menor experiencia</span>
                </div>
            </div>-->
        </div>
    </section>

    <!-- POPOVER FLOTANTE -->
    <div id="matrixPopover" class="matrix-popover">
        <div id="popoverLinks" style="display:flex; flex-direction:column; gap:6px;"></div>
    </div>

    <!-- 5. SECCIÓN DE GRÁFICO FLOURISH START -->
    <section class="w-full flex flex-col lg:flex-row items-stretch border-t border-gray-200 bg-white">
        <!-- Columna Texto (1/3) -->
        <div class="w-full lg:w-1/3 bg-primary p-12 md:p-20 flex items-center relative overflow-hidden group">
            <!-- Efecto de brillo sutil -->
            <div class="absolute -top-24 -right-24 w-64 h-64 bg-white/10 rounded-full blur-3xl transition-transform duration-700 group-hover:scale-125"></div>
            
            <p class="text-white text-2xl md:text-3xl font-serif font-bold leading-tight relative z-10">
                Las organizaciones que demandan los servicios del Centro para la Competitividad y el Desarrollo (CCD) tienen sus operaciones, accionistas o matrices corporativas en los cinco continentes.
            </p>
        </div>
        
        <!-- Columna Mapa (2/3) -->
        <div class="w-full lg:w-2/3 bg-white p-6 md:p-12 flex items-center justify-center">
            <div class="flourish-clean-wrapper w-full">
                <div class="flourish-embed flourish-chart w-full" data-src="visualisation/28019801" data-width="100%">
                    <script is:inline src="https://public.flourish.studio/resources/embed.js"></script>
                    <noscript><img src="https://public.flourish.studio/visualisation/28019801/thumbnail" width="100%" alt="visualization" /></noscript>
                </div>
            </div>
        </div>
    </section>
    <!-- SECCIÓN DE GRÁFICO FLOURISH END -->



    <script is:inline>
    // @ts-nocheck
    (function() {
        var IND_NAMES = {
            agropecuario: "Agropecuario",
            agroexportacion: "Agroexportación",
            educacion: "Educación",
            hidrocarburos: "Hidrocarburos",
            infraestructura: "Infraestructura y Construcción",
            inteligencia: "Inteligencia Artificial",
            manufactura: "Manufactura",
            mineria: "Minería",
            seguridad: "Seguridad Ciudadana",
            publico: "Sector Público",
            portuarios: "Servicios Portuarios",
            financiero: "Sistema Financiero",
            tecnologia: "Tecnología"
        };

        var CAP_DATA = {
            competitividad: { name: "Competitividad", link: "/capacidades/competitividad", color: "#00B050" },
            desarrollo: { name: "Desarrollo", link: "/capacidades/desarrollo", color: "#00B050" },
            corredores: { name: "Corredores Económicos Territoriales", link: "/capacidades/corredores", color: "#00B050" },

           
            fortalecimiento:     { name: "Fortalecimiento de Capacidades",  link: "/capacidades/fortalecimiento",     color: "#E26B0A" },
            politica:     { name: "Política Fiscal",  link: "/capacidades/politica",     color: "#E26B0A" },
            fondos_sociales:     { name: "Fondos Sociales",  link: "/capacidades/fondos-sociales",     color: "#E26B0A" },
            fondos_de_estabilizacion:     { name: "Mecanismos Reductores de Riesgos",  link: "/capacidades/fondos-de-estabilizacion",     color: "#E26B0A" },




            estudios:     { name: "Estudios Económicos",          link: "/capacidades/estudios",    color: "#0070C0" },

            inversiones:    { name: "Inversiones y Proyectos",      link: "/capacidades/inversiones",   color: "#76933C" },
            evaluacion:    { name: "Evaluación de Proyectos",      link: "/capacidades/evaluacion",   color: "#76933C" },

            legal:{ name: "Legal",                        link: "/capacidades/legal", color: "#60497A" },
            inteligencia_artificial:     { name: "Inteligencia Artificial y Analítica", link: "/capacidades/inteligencia_artificial",    color: "#31869B" }
        };

        function setup() {
            var popover = document.getElementById("matrixPopover");
            var linksDiv = document.getElementById("popoverLinks");
            var table = document.getElementById("matrizExperiencia");
            var hoverTimer = null;

            if (!popover || !table) return;

            function hidePopover() {
                popover.classList.remove("show");
                popover._activeBtn = null;
            }

            function showPopover(btn) {
                var capSlugs = btn.getAttribute("data-cap-slug");
                var indSlug = btn.getAttribute("data-ind");
                if (!capSlugs || !indSlug) return;

                var indName = IND_NAMES[indSlug] || indSlug;
                
                var capSlugsArray = capSlugs.split(',').map(function(s) { return s.trim(); });
                var linksHtml = '';
                
                capSlugsArray.forEach(function(slug) {
                    var cap = CAP_DATA[slug];
                    if (cap) {
                        linksHtml += '<a href="' + cap.link + '" style="display:flex;align-items:center;gap:10px;padding:14px 16px;border-radius:0;background:' + cap.color + ';color:#fff;font-size:14px;font-weight:600;text-decoration:none;transition:opacity 0.15s;margin-bottom:6px;">' +
                            '<svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>' +
                            cap.name + '</a>';
                    }
                });

                if (!linksHtml) return;

                linksHtml += '<a href="/industrias/' + indSlug + '" style="display:flex;align-items:center;gap:10px;padding:14px 16px;border-radius:0;background:#910121;color:#fff;font-size:14px;font-weight:600;text-decoration:none;transition:background 0.15s;">' +
                    '<svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>' +
                    indName + '</a>';

                linksDiv.innerHTML = linksHtml;

                // Position: use absolute positioning relative to the page
                var rect = btn.getBoundingClientRect();
                var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                var scrollLeft = window.pageXOffset || document.documentElement.scrollLeft;

                var isFirstShow = !popover.classList.contains("show");
                if (isFirstShow) {
                    popover.style.transition = "none";
                }

                var popRect = popover.getBoundingClientRect();
                var top = rect.bottom + scrollTop + 2; // Closer to the cell
                var left = rect.left + scrollLeft + (rect.width / 2) - (popRect.width / 2);

                // Keep within viewport
                if (left < 10) left = 10;
                if (left + popRect.width > window.innerWidth - 10) {
                    left = window.innerWidth - popRect.width - 10;
                }
                // If it goes below viewport, show above
                if (rect.bottom + popRect.height + 10 > window.innerHeight) {
                    top = rect.top + scrollTop - popRect.height - 2;
                }

                popover.style.top = top + "px";
                popover.style.left = left + "px";

                if (isFirstShow) {
                    void popover.offsetWidth; // force reflow
                    popover.style.transition = ""; 
                    popover.classList.add("show");
                }
            }

            // Use event delegation on the TABLE for all .matrix-cell hovers
            table.addEventListener("mouseover", function(e) {
                var btn = e.target.closest(".matrix-cell");
                if (!btn) {
                    if (hoverTimer) {
                        clearTimeout(hoverTimer);
                        hoverTimer = null;
                    }
                    return;
                }

                if (popover._activeBtn !== btn) {
                    if (hoverTimer) clearTimeout(hoverTimer);
                    
                    hoverTimer = setTimeout(function() {
                        showPopover(btn);
                        popover._activeBtn = btn;
                    }, 150); // Small delay to avoid flickering/accidental switches
                }
            });

            // Keep popover visible when hovering over it
            popover.addEventListener("mouseenter", function() {
                if (hoverTimer) {
                    clearTimeout(hoverTimer);
                    hoverTimer = null;
                }
            });

            // Also keep the existing click functionality outside to be safe, but just hide
            document.addEventListener("click", function(e) {
                if (!popover.classList.contains("show")) return;
                if (popover.contains(e.target)) return;
                if (e.target.closest && e.target.closest(".matrix-cell")) return;
                hidePopover();
            });

            // Close on Escape
            document.addEventListener("keydown", function(e) {
                if (e.key === "Escape") {
                    hidePopover();
                }
            });
        }

        // Run setup when DOM is ready
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", setup);
        } else {
            setup();
        }
        // Also run on Astro page transitions
        document.addEventListener("astro:page-load", setup);
    })();
    </script>

</Layout>

