---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";

// Contenido para la página de Países
// Usamos imágenes de referencia que el usuario ha estado utilizando o placeholders premium
const headerImage =
    "https://res.cloudinary.com/ccdcloudy/image/upload/v1773305978/Web%20CCD/paises/comercio-exterior_indice-de-conectividad-global-050424-010226_gvj4pp.jpg";
const introImage =
    "https://res.cloudinary.com/ccdcloudy/image/upload/v1773305978/Web%20CCD/paises/comercio-exterior_indice-de-conectividad-global-050424-010226_gvj4pp.jpg"; // Placeholder para imagen de impacto
---

<Layout title="Países - CCD">
    <!-- 1. BANNER CON IMAGEN -->
    <PageHeader title="Países" backgroundImage={headerImage} />

    <!-- 2. PÁRRAFO DE SOLO TEXTO -->
    <section class="bg-white py-20 md:py-28">
        <div class="container mx-auto px-6 lg:px-12 max-w-5xl text-center">
            <p
                class="font-sans text-2xl md:text-3xl text-gray-700 leading-relaxed font-bold"
            >
                El Centro para la Competitividad y el Desarrollo (CCD) es un socio estratégico de organizaciones que operan globalmente y tienen como objetivo impulsar la competitividad y el desarrollo del entorno territorial comunal, local, regional y nacional donde realizarán sus actividades.
            </p>
        </div>
    </section>

    <!-- 3. PÁRRAFO ACOMPAÑADO DE IMAGEN AL LADO -->
    <section
        class="w-full flex flex-col lg:flex-row items-stretch border-t border-gray-100"
    >
        <!-- Imagen -->
        <div
            class="relative w-full lg:w-1/2 min-h-[400px] lg:min-h-[600px] overflow-hidden"
        >
            <img
                src="https://res.cloudinary.com/ccdcloudy/image/upload/v1774377986/Web%20CCD/paises/global_eppyyo.jpg"
                alt="Impacto global"
                class="absolute inset-0 w-full h-full object-cover"
            />
        </div>

        <!-- Texto con fondo sutil -->
        <div
            class="w-full lg:w-1/2 bg-secondary-light/50 py-16 px-12 md:px-20 flex flex-col justify-center"
        >
            
            <p
                class="font-sans text-xl md:text-2xl text-gray-800 leading-relaxed"
            >
                Los servicios especializados de asistencia técnica y consultoría que brinda el Centro para la Competitividad y el Desarrollo (CCD) se encuentran en las áreas de competitividad y desarrollo, política y gestión pública, estudios económicos, legal y CCD Tech, principalmente con amplia experiencia en las industrias agropecuario, agroexportación, educación, hidrocarburos, infraestructura y construcción, inteligencia artificial, manufactura, minería, seguridad ciudadana, sector público, servicios portuarios, sistema financiero y tecnología.

            </p>
        </div>
    </section>

    <!-- 4. MATRIZ DE EXPERIENCIA -->
    <section class="bg-gray-200 py-20 md:py-28 border-t border-gray-100 overflow-x-auto">
        <div class="container mx-auto px-6 lg:px-12 max-w-[1600px]">
            <!-- Título -->
            <h2 class="font-serif text-3xl md:text-5xl font-bold text-gray-900 mb-12 text-center animate-fade-in-up">
                Matriz de Experiencia
            </h2>
            

            
            <!-- La tabla -->
            <div class="relative w-full bg-white  shadow-sm border border-gray-100 overflow-hidden">
                <table class="w-full border-collapse experience-matrix text-sm font-sans" id="matrizExperiencia" style="table-layout: fixed; min-width: 1000px;">
                    
                    <!-- ENCABEZADO -->
                    <colgroup>
                        <col style="width: 130px;" />
                        {Array(13).fill(0).map(() => <col style="width: calc(100% / 13);" />)}
                    </colgroup>
                    
                    <thead>
                        <tr>
                            <!-- Esquina superior izquierda -->
                            <th class="sticky left-0 z-20" rowspan="2" style="background-color:#910121;">
                                <div class="px-2 py-3 text-center">
                                    <div class=" text-white font-bold text-base tracking-wide">Áreas</div>
                                </div>
                            </th>
                            <!-- Título "Industrias" -->
                            <th colspan="13" class="py-3 px-4 text-center text-white font-bold text-base tracking-wide" style="background-color:#910121;">
                                Industrias
                            </th>
                        </tr>
                        <tr>
                            <!-- Cabeceras de industrias -->
                            {["Agropecuario","Agroexportación","Educación","Hidrocarburos","Infraestructura y Construcción","Inteligencia Artificial","Manufactura","Minería","Seguridad Ciudadana","Sector Público","Servicios Portuarios","Sistema Financiero","Tecnología"].map((ind) => (
                                <th class="py-3 px-1 text-center text-white text-xs font-medium leading-tight" style="background-color:#910121; overflow: hidden; text-overflow: ellipsis;">
                                    {ind}
                                </th>
                            ))}
                        </tr>
                    </thead>

                    <!-- CUERPO DE LA MATRIZ -->
                    <tbody>
                        {/* cada fila: [nombreCapacidad, bgFila, [colores por industria o '' si vacío]] */}
                        {[
                            {
                                cap: "Competitividad y Desarrollo",
                                rowBg: "#00B050",
                                cells: [
                                    { color: "#00B050", slug: "competitividad, desarrollo, corredores", ind: "agropecuario" },
                                    { color: "#00B050", slug: "competitividad, desarrollo, corredores", ind: "agroexportacion" },
                                    { color: "#00B050", slug: "competitividad, desarrollo, corredores", ind: "educacion" },
                                    { color: "#00B050", slug: "competitividad, desarrollo, corredores", ind: "hidrocarburos" },
                                    { color: "#00B050", slug: "competitividad, desarrollo, corredores", ind: "infraestructura" },
                                    { color: "#00B050", slug: "competitividad, desarrollo, corredores", ind: "inteligencia" },
                                    { color: "#00B050", slug: "competitividad, desarrollo, corredores", ind: "manufactura" },
                                    { color: "#00B050", slug: "competitividad, desarrollo, corredores", ind: "mineria" },
                                    { color: "#00B050", slug: "competitividad, desarrollo, corredores", ind: "seguridad" },
                                    { color: "#00B050", slug: "competitividad, desarrollo, corredores", ind: "publico" },
                                    { color: "#00B050", slug: "competitividad, desarrollo, corredores", ind: "portuarios" },
                                    { color: "#00B050", slug: "competitividad, desarrollo, corredores", ind: "financiero" },
                                    { color: "#00B050", slug: "competitividad, desarrollo, corredores", ind: "tecnologia" },
                                ]
                            },
                            {
                                cap: "Política y Gestión Pública",
                                rowBg: "#E26B0A",
                                cells: [
                                    { color: "#E26B0A", slug: "fortalecimiento,politica,fondos_sociales,fondos_de_estabilizacion", ind: "agropecuario" },
                                    { color: "#E26B0A", slug: "fortalecimiento,politica,fondos_sociales,fondos_de_estabilizacion", ind: "agroexportacion" },
                                    { color: "#E26B0A", slug: "fortalecimiento,politica,fondos_sociales,fondos_de_estabilizacion", ind: "educacion" },
                                    { color: "#E26B0A", slug: "fortalecimiento,politica,fondos_sociales,fondos_de_estabilizacion", ind: "hidrocarburos" },
                                    { color: "#E26B0A", slug: "fortalecimiento,politica,fondos_sociales,fondos_de_estabilizacion", ind: "infraestructura" },
                                    { color: "#E26B0A", slug: "fortalecimiento,politica,fondos_sociales,fondos_de_estabilizacion", ind: "inteligencia" },
                                    { color: "#E26B0A", slug: "fortalecimiento,politica,fondos_sociales,fondos_de_estabilizacion", ind: "manufactura" },
                                    { color: "#E26B0A", slug: "fortalecimiento,politica,fondos_sociales,fondos_de_estabilizacion", ind: "mineria" },
                                    { color: "#E26B0A", slug: "fortalecimiento,politica,fondos_sociales,fondos_de_estabilizacion", ind: "seguridad" },
                                    { color: "#E26B0A", slug: "fortalecimiento,politica,fondos_sociales,fondos_de_estabilizacion", ind: "publico" },
                                    { color: "#E26B0A", slug: "fortalecimiento,politica,fondos_sociales,fondos_de_estabilizacion", ind: "portuarios" },
