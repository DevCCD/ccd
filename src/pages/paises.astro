                                    { color: "#E26B0A", slug: "fortalecimiento,politica,fondos_sociales,fondos_de_estabilizacion", ind: "tecnologia" },
                                ]
                            },
                            {
                                cap: "Estudios Económicos",
                                rowBg: "#0070C0",
                                cells: [
                                    { color: "#0070C0", slug: "estudios", ind: "agropecuario" },
                                    { color: "#0070C0", slug: "estudios", ind: "agroexportacion" },
                                    { color: "#0070C0", slug: "estudios", ind: "educacion" },
                                    { color: "#0070C0", slug: "estudios", ind: "hidrocarburos" },
                                    { color: "#0070C0", slug: "estudios", ind: "infraestructura" },
